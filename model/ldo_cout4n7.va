                       + (-3.609219e-06)*max(vdrp-(1.421648e+00),0) + (-3.356624e-06)*max(vdrp-(1.449143e+00),0) + (-3.119874e-06)*max(vdrp-(1.476766e+00),0) + (-2.897755e-06)*max(vdrp-(1.504508e+00),0)
                       + (-2.689412e-06)*max(vdrp-(1.532362e+00),0) + (-2.493867e-06)*max(vdrp-(1.560320e+00),0) + (-2.310225e-06)*max(vdrp-(1.588377e+00),0) + (-2.137759e-06)*max(vdrp-(1.616525e+00),0)
                       + (-1.975630e-06)*max(vdrp-(1.644757e+00),0) + (-1.823202e-06)*max(vdrp-(1.673069e+00),0) + (-1.679841e-06)*max(vdrp-(1.701454e+00),0) + (-1.544931e-06)*max(vdrp-(1.729906e+00),0)
                       + (-1.417870e-06)*max(vdrp-(1.758422e+00),0) + (-1.298190e-06)*max(vdrp-(1.786995e+00),0) + (-1.185452e-06)*max(vdrp-(1.815621e+00),0) + (-1.079098e-06)*max(vdrp-(1.844296e+00),0)
                       + (-9.786941e-07)*max(vdrp-(1.873015e+00),0) + (-8.844283e-07)*max(vdrp-(1.901775e+00),0) + (-7.945286e-07)*max(vdrp-(1.930571e+00),0) + (-7.103532e-07)*max(vdrp-(1.959400e+00),0)
                       + (-6.305246e-07)*max(vdrp-(1.988259e+00),0) + (-5.549568e-07)*max(vdrp-(2.017144e+00),0) + (-4.838124e-07)*max(vdrp-(2.046053e+00),0) + (-4.163064e-07)*max(vdrp-(2.074981e+00),0)
                       + (-3.521430e-07)*max(vdrp-(2.103927e+00),0) + (-2.915106e-07)*max(vdrp-(2.132888e+00),0) + (-2.343647e-07)*max(vdrp-(2.161861e+00),0) + (-1.797146e-07)*max(vdrp-(2.190843e+00),0)
                       + (-1.282423e-07)*max(vdrp-(2.219834e+00),0) + (-7.944350e-08)*max(vdrp-(2.248830e+00),0) + (-3.234301e-08)*max(vdrp-(2.277829e+00),0) + (1.117702e-08)*max(vdrp-(2.306829e+00),0)
                       + (5.351203e-08)*max(vdrp-(2.335829e+00),0) + (9.301177e-08)*max(vdrp-(2.364827e+00),0) + (1.313535e-07)*max(vdrp-(2.393821e+00),0) + (1.671196e-07)*max(vdrp-(2.422809e+00),0)
                       + (2.012699e-07)*max(vdrp-(2.451790e+00),0) + (2.342878e-07)*max(vdrp-(2.480763e+00),0) + (2.652254e-07)*max(vdrp-(2.509726e+00),0) + (2.945624e-07)*max(vdrp-(2.538678e+00),0)
