                       + (6.814865e-07)*max(vdrp-(3.142376e+00),0) + (6.929395e-07)*max(vdrp-(3.170859e+00),0) + (7.029712e-07)*max(vdrp-(3.199313e+00),0) + (7.130591e-07)*max(vdrp-(3.227739e+00),0)
