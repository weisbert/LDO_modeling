                       + (9.127052e-04)*max(vdrp-(2.416126e-02),0) + (9.014878e-04)*max(vdrp-(2.425812e-02),0) + (8.855312e-04)*max(vdrp-(2.435455e-02),0) + (8.734383e-04)*max(vdrp-(2.445057e-02),0)
