                       + (-2.034720e-04)*max(vdrp-(3.444718e-02),0) + (-2.088435e-04)*max(vdrp-(3.453075e-02),0) + (-2.141859e-04)*max(vdrp-(3.461440e-02),0) + (-2.194987e-04)*max(vdrp-(3.469813e-02),0)
                       + (-2.276237e-04)*max(vdrp-(3.478193e-02),0) + (-2.300271e-04)*max(vdrp-(3.486581e-02),0) + (-2.352468e-04)*max(vdrp-(3.494977e-02),0) + (-2.432601e-04)*max(vdrp-(3.503381e-02),0)
                       + (-2.455832e-04)*max(vdrp-(3.511794e-02),0) + (-2.535182e-04)*max(vdrp-(3.520216e-02),0) + (-2.585931e-04)*max(vdrp-(3.528646e-02),0) + (-2.608315e-04)*max(vdrp-(3.537086e-02),0)
                       + (-2.658486e-04)*max(vdrp-(3.545536e-02),0) + (-2.736188e-04)*max(vdrp-(3.553994e-02),0) + (-2.757686e-04)*max(vdrp-(3.562463e-02),0) + (-2.806768e-04)*max(vdrp-(3.570941e-02),0)
                       + (-2.883166e-04)*max(vdrp-(3.579430e-02),0) + (-2.931360e-04)*max(vdrp-(3.587929e-02),0) + (-2.924066e-04)*max(vdrp-(3.596438e-02),0) + (-2.999244e-04)*max(vdrp-(3.604958e-02),0)
                       + (-3.073819e-04)*max(vdrp-(3.613489e-02),0) + (-3.093106e-04)*max(vdrp-(3.622031e-02),0) + (-3.112209e-04)*max(vdrp-(3.630585e-02),0) + (-3.185506e-04)*max(vdrp-(3.639150e-02),0)
                       + (-3.231056e-04)*max(vdrp-(3.647726e-02),0) + (-3.249153e-04)*max(vdrp-(3.656315e-02),0) + (-3.320986e-04)*max(vdrp-(3.664915e-02),0) + (-3.338398e-04)*max(vdrp-(3.673528e-02),0)
                       + (-3.382425e-04)*max(vdrp-(3.682153e-02),0) + (-3.426025e-04)*max(vdrp-(3.690791e-02),0) + (-3.442549e-04)*max(vdrp-(3.699442e-02),0) + (-3.538577e-04)*max(vdrp-(3.708105e-02),0)
                       + (-3.501262e-04)*max(vdrp-(3.716782e-02),0) + (-3.596253e-04)*max(vdrp-(3.725472e-02),0) + (-3.611351e-04)*max(vdrp-(3.734176e-02),0) + (-3.652489e-04)*max(vdrp-(3.742893e-02),0)
