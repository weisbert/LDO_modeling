                       + (-6.355587e-06)*max(vdrp-(1.207237e+00),0) + (-5.927493e-06)*max(vdrp-(1.233383e+00),0) + (-5.526957e-06)*max(vdrp-(1.259733e+00),0) + (-5.152320e-06)*max(vdrp-(1.286276e+00),0)
