                       + (-3.609219e-06)*max(vdrp-(1.421536e+00),0) + (-3.356624e-06)*max(vdrp-(1.449031e+00),0) + (-3.119874e-06)*max(vdrp-(1.476653e+00),0) + (-2.897755e-06)*max(vdrp-(1.504395e+00),0)
                       + (-2.689412e-06)*max(vdrp-(1.532249e+00),0) + (-2.493867e-06)*max(vdrp-(1.560208e+00),0) + (-2.310225e-06)*max(vdrp-(1.588264e+00),0) + (-2.137759e-06)*max(vdrp-(1.616412e+00),0)
                       + (-1.975630e-06)*max(vdrp-(1.644645e+00),0) + (-1.823202e-06)*max(vdrp-(1.672956e+00),0) + (-1.679841e-06)*max(vdrp-(1.701341e+00),0) + (-1.544931e-06)*max(vdrp-(1.729794e+00),0)
                       + (-1.417870e-06)*max(vdrp-(1.758309e+00),0) + (-1.298190e-06)*max(vdrp-(1.786882e+00),0) + (-1.185452e-06)*max(vdrp-(1.815508e+00),0) + (-1.079098e-06)*max(vdrp-(1.844183e+00),0)
                       + (-9.786941e-07)*max(vdrp-(1.872902e+00),0) + (-8.844283e-07)*max(vdrp-(1.901662e+00),0) + (-7.945286e-07)*max(vdrp-(1.930458e+00),0) + (-7.103532e-07)*max(vdrp-(1.959288e+00),0)
                       + (-6.305246e-07)*max(vdrp-(1.988147e+00),0) + (-5.549568e-07)*max(vdrp-(2.017032e+00),0) + (-4.838124e-07)*max(vdrp-(2.045940e+00),0) + (-4.163064e-07)*max(vdrp-(2.074869e+00),0)
                       + (-3.521430e-07)*max(vdrp-(2.103814e+00),0) + (-2.915106e-07)*max(vdrp-(2.132775e+00),0) + (-2.343647e-07)*max(vdrp-(2.161748e+00),0) + (-1.797146e-07)*max(vdrp-(2.190731e+00),0)
                       + (-1.282423e-07)*max(vdrp-(2.219721e+00),0) + (-7.944350e-08)*max(vdrp-(2.248717e+00),0) + (-3.234301e-08)*max(vdrp-(2.277716e+00),0) + (1.117702e-08)*max(vdrp-(2.306716e+00),0)
                       + (5.351203e-08)*max(vdrp-(2.335716e+00),0) + (9.301177e-08)*max(vdrp-(2.364714e+00),0) + (1.313535e-07)*max(vdrp-(2.393708e+00),0) + (1.671196e-07)*max(vdrp-(2.422696e+00),0)
