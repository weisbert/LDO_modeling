                       + (6.814865e-07)*max(vdrp-(3.142264e+00),0) + (6.929395e-07)*max(vdrp-(3.170746e+00),0) + (7.029712e-07)*max(vdrp-(3.199201e+00),0) + (7.130591e-07)*max(vdrp-(3.227627e+00),0)
