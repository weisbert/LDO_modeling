                       + (-3.177117e-05)*max(vdrp-(9.145538e-02),0) + (-3.019522e-05)*max(vdrp-(9.458610e-02),0) + (-2.879964e-05)*max(vdrp-(9.773168e-02),0) + (-2.755322e-05)*max(vdrp-(1.008916e-01),0)
                       + (-2.643632e-05)*max(vdrp-(1.040653e-01),0) + (-2.543626e-05)*max(vdrp-(1.072524e-01),0) + (-2.453338e-05)*max(vdrp-(1.104524e-01),0) + (-2.371853e-05)*max(vdrp-(1.136651e-01),0)
                       + (-2.297543e-05)*max(vdrp-(1.168900e-01),0) + (-2.230747e-05)*max(vdrp-(1.201270e-01),0) + (-2.169351e-05)*max(vdrp-(1.233756e-01),0) + (-2.113380e-05)*max(vdrp-(1.266358e-01),0)
                       + (-2.062676e-05)*max(vdrp-(1.299072e-01),0) + (-2.015800e-05)*max(vdrp-(1.331897e-01),0) + (-1.973012e-05)*max(vdrp-(1.364831e-01),0) + (-1.934023e-05)*max(vdrp-(1.397873e-01),0)
                       + (-1.897827e-05)*max(vdrp-(1.431020e-01),0) + (-1.864715e-05)*max(vdrp-(1.464272e-01),0) + (-1.834965e-05)*max(vdrp-(1.497627e-01),0) + (-1.806720e-05)*max(vdrp-(1.531085e-01),0)
                       + (-1.781710e-05)*max(vdrp-(1.564644e-01),0) + (-1.758454e-05)*max(vdrp-(1.598304e-01),0) + (-1.737435e-05)*max(vdrp-(1.632063e-01),0) + (-1.718082e-05)*max(vdrp-(1.665922e-01),0)
