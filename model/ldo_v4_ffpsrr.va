                       + (-3.177117e-05)*max(vdrp-(9.256599e-02),0) + (-3.019522e-05)*max(vdrp-(9.569670e-02),0) + (-2.879964e-05)*max(vdrp-(9.884228e-02),0) + (-2.755322e-05)*max(vdrp-(1.020022e-01),0)
                       + (-2.643632e-05)*max(vdrp-(1.051759e-01),0) + (-2.543626e-05)*max(vdrp-(1.083630e-01),0) + (-2.453338e-05)*max(vdrp-(1.115630e-01),0) + (-2.371853e-05)*max(vdrp-(1.147757e-01),0)
                       + (-2.297543e-05)*max(vdrp-(1.180006e-01),0) + (-2.230747e-05)*max(vdrp-(1.212376e-01),0) + (-2.169351e-05)*max(vdrp-(1.244862e-01),0) + (-2.113380e-05)*max(vdrp-(1.277464e-01),0)
                       + (-2.062676e-05)*max(vdrp-(1.310178e-01),0) + (-2.015800e-05)*max(vdrp-(1.343003e-01),0) + (-1.973012e-05)*max(vdrp-(1.375937e-01),0) + (-1.934023e-05)*max(vdrp-(1.408979e-01),0)
                       + (-1.897827e-05)*max(vdrp-(1.442126e-01),0) + (-1.864715e-05)*max(vdrp-(1.475378e-01),0) + (-1.834965e-05)*max(vdrp-(1.508733e-01),0) + (-1.806720e-05)*max(vdrp-(1.542191e-01),0)
                       + (-1.781710e-05)*max(vdrp-(1.575750e-01),0) + (-1.758454e-05)*max(vdrp-(1.609410e-01),0) + (-1.737435e-05)*max(vdrp-(1.643169e-01),0) + (-1.718082e-05)*max(vdrp-(1.677028e-01),0)
