                       + (-8.389836e-06)*max(vdrp-(1.106037e+00),0) + (-7.827816e-06)*max(vdrp-(1.131250e+00),0) + (-7.303472e-06)*max(vdrp-(1.156714e+00),0) + (-6.813635e-06)*max(vdrp-(1.182417e+00),0)
                       + (-6.355587e-06)*max(vdrp-(1.208348e+00),0) + (-5.927493e-06)*max(vdrp-(1.234493e+00),0) + (-5.526957e-06)*max(vdrp-(1.260843e+00),0) + (-5.152320e-06)*max(vdrp-(1.287387e+00),0)
