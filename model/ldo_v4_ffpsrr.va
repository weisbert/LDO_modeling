                       + (-3.609219e-06)*max(vdrp-(1.422647e+00),0) + (-3.356624e-06)*max(vdrp-(1.450141e+00),0) + (-3.119874e-06)*max(vdrp-(1.477764e+00),0) + (-2.897755e-06)*max(vdrp-(1.505506e+00),0)
                       + (-2.689412e-06)*max(vdrp-(1.533360e+00),0) + (-2.493867e-06)*max(vdrp-(1.561318e+00),0) + (-2.310225e-06)*max(vdrp-(1.589375e+00),0) + (-2.137759e-06)*max(vdrp-(1.617523e+00),0)
                       + (-1.975630e-06)*max(vdrp-(1.645755e+00),0) + (-1.823202e-06)*max(vdrp-(1.674067e+00),0) + (-1.679841e-06)*max(vdrp-(1.702452e+00),0) + (-1.544931e-06)*max(vdrp-(1.730904e+00),0)
                       + (-1.417870e-06)*max(vdrp-(1.759420e+00),0) + (-1.298190e-06)*max(vdrp-(1.787993e+00),0) + (-1.185452e-06)*max(vdrp-(1.816619e+00),0) + (-1.079098e-06)*max(vdrp-(1.845294e+00),0)
                       + (-9.786941e-07)*max(vdrp-(1.874013e+00),0) + (-8.844283e-07)*max(vdrp-(1.902773e+00),0) + (-7.945286e-07)*max(vdrp-(1.931569e+00),0) + (-7.103532e-07)*max(vdrp-(1.960398e+00),0)
                       + (-6.305246e-07)*max(vdrp-(1.989257e+00),0) + (-5.549568e-07)*max(vdrp-(2.018142e+00),0) + (-4.838124e-07)*max(vdrp-(2.047051e+00),0) + (-4.163064e-07)*max(vdrp-(2.075979e+00),0)
                       + (-3.521430e-07)*max(vdrp-(2.104925e+00),0) + (-2.915106e-07)*max(vdrp-(2.133886e+00),0) + (-2.343647e-07)*max(vdrp-(2.162859e+00),0) + (-1.797146e-07)*max(vdrp-(2.191842e+00),0)
