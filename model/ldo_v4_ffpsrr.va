                       + (5.351203e-08)*max(vdrp-(2.336827e+00),0) + (9.301177e-08)*max(vdrp-(2.365825e+00),0) + (1.313535e-07)*max(vdrp-(2.394819e+00),0) + (1.671196e-07)*max(vdrp-(2.423807e+00),0)
