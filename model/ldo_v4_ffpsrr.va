                       + (6.331160e-07)*max(vdrp-(3.029171e+00),0) + (6.465199e-07)*max(vdrp-(3.057762e+00),0) + (6.585215e-07)*max(vdrp-(3.086326e+00),0) + (6.705875e-07)*max(vdrp-(3.114864e+00),0)
                       + (6.814865e-07)*max(vdrp-(3.143374e+00),0) + (6.929395e-07)*max(vdrp-(3.171857e+00),0) + (7.029712e-07)*max(vdrp-(3.200311e+00),0) + (7.130591e-07)*max(vdrp-(3.228737e+00),0)
