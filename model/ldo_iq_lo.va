                       + (-3.609116e-06)*max(vdrp-(1.420117e+00),0) + (-3.356524e-06)*max(vdrp-(1.447612e+00),0) + (-3.119725e-06)*max(vdrp-(1.475235e+00),0) + (-2.897687e-06)*max(vdrp-(1.502977e+00),0)
                       + (-2.689294e-06)*max(vdrp-(1.530831e+00),0) + (-2.493803e-06)*max(vdrp-(1.558789e+00),0) + (-2.310113e-06)*max(vdrp-(1.586846e+00),0) + (-2.137674e-06)*max(vdrp-(1.614994e+00),0)
                       + (-1.975571e-06)*max(vdrp-(1.643226e+00),0) + (-1.823119e-06)*max(vdrp-(1.671538e+00),0) + (-1.679785e-06)*max(vdrp-(1.699923e+00),0) + (-1.544851e-06)*max(vdrp-(1.728376e+00),0)
                       + (-1.417791e-06)*max(vdrp-(1.756891e+00),0) + (-1.298161e-06)*max(vdrp-(1.785464e+00),0) + (-1.185375e-06)*max(vdrp-(1.814090e+00),0) + (-1.079046e-06)*max(vdrp-(1.842765e+00),0)
                       + (-9.786910e-07)*max(vdrp-(1.871485e+00),0) + (-8.843049e-07)*max(vdrp-(1.900244e+00),0) + (-7.945264e-07)*max(vdrp-(1.929041e+00),0) + (-7.103513e-07)*max(vdrp-(1.957870e+00),0)
                       + (-6.302831e-07)*max(vdrp-(1.986729e+00),0) + (-5.551949e-07)*max(vdrp-(2.015614e+00),0) + (-4.838110e-07)*max(vdrp-(2.044522e+00),0) + (-4.160665e-07)*max(vdrp-(2.073451e+00),0)
                       + (-3.521423e-07)*max(vdrp-(2.102397e+00),0) + (-2.915100e-07)*max(vdrp-(2.131358e+00),0) + (-2.343642e-07)*max(vdrp-(2.160331e+00),0) + (-1.797143e-07)*max(vdrp-(2.189313e+00),0)
                       + (-1.280042e-07)*max(vdrp-(2.218304e+00),0) + (-7.944339e-08)*max(vdrp-(2.247300e+00),0) + (-3.258077e-08)*max(vdrp-(2.276299e+00),0) + (1.141481e-08)*max(vdrp-(2.305299e+00),0)
                       + (5.351195e-08)*max(vdrp-(2.334299e+00),0) + (9.301164e-08)*max(vdrp-(2.363297e+00),0) + (1.313533e-07)*max(vdrp-(2.392291e+00),0) + (1.671194e-07)*max(vdrp-(2.421279e+00),0)
