                       + (6.817326e-07)*max(vdrp-(3.140847e+00),0) + (6.929395e-07)*max(vdrp-(3.169329e+00),0) + (7.027237e-07)*max(vdrp-(3.197784e+00),0) + (7.130586e-07)*max(vdrp-(3.226210e+00),0)
