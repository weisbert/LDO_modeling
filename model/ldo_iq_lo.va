                       + (-2.843728e-05)*max(vdrp-(9.848658e-02),0) + (-2.717246e-05)*max(vdrp-(1.017909e-01),0) + (-2.603707e-05)*max(vdrp-(1.051101e-01),0) + (-2.501714e-05)*max(vdrp-(1.084437e-01),0)
                       + (-2.409246e-05)*max(vdrp-(1.117913e-01),0) + (-2.325787e-05)*max(vdrp-(1.151524e-01),0) + (-2.249807e-05)*max(vdrp-(1.185268e-01),0) + (-2.180712e-05)*max(vdrp-(1.219139e-01),0)
                       + (-2.117081e-05)*max(vdrp-(1.253137e-01),0) + (-2.059424e-05)*max(vdrp-(1.287257e-01),0) + (-2.005870e-05)*max(vdrp-(1.321497e-01),0) + (-1.956972e-05)*max(vdrp-(1.355856e-01),0)
                       + (-1.911929e-05)*max(vdrp-(1.390330e-01),0) + (-1.870137e-05)*max(vdrp-(1.424918e-01),0) + (-1.831343e-05)*max(vdrp-(1.459619e-01),0) + (-1.795634e-05)*max(vdrp-(1.494430e-01),0)
                       + (-1.762766e-05)*max(vdrp-(1.529350e-01),0) + (-1.731859e-05)*max(vdrp-(1.564378e-01),0) + (-1.703348e-05)*max(vdrp-(1.599513e-01),0) + (-1.676695e-05)*max(vdrp-(1.634753e-01),0)
                       + (-1.652015e-05)*max(vdrp-(1.670098e-01),0) + (-1.629263e-05)*max(vdrp-(1.705546e-01),0) + (-1.607765e-05)*max(vdrp-(1.741096e-01),0) + (-1.587963e-05)*max(vdrp-(1.776749e-01),0)
