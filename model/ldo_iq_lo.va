                       + (-8.392892e-06)*max(vdrp-(1.103506e+00),0) + (-7.829515e-06)*max(vdrp-(1.128719e+00),0) + (-7.304382e-06)*max(vdrp-(1.154184e+00),0) + (-6.814039e-06)*max(vdrp-(1.179887e+00),0)
