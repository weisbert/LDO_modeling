                       + (-8.389836e-06)*max(vdrp-(1.104860e+00),0) + (-7.827816e-06)*max(vdrp-(1.130073e+00),0) + (-7.303472e-06)*max(vdrp-(1.155537e+00),0) + (-6.813635e-06)*max(vdrp-(1.181240e+00),0)
