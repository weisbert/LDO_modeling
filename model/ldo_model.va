                       + (6.814865e-07)*max(vdrp-(3.142197e+00),0) + (6.929395e-07)*max(vdrp-(3.170680e+00),0) + (7.029712e-07)*max(vdrp-(3.199134e+00),0) + (7.130591e-07)*max(vdrp-(3.227561e+00),0)
