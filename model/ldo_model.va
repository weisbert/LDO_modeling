// ============================================================
// Behavioral LDO model for Cadence Spectre  (auto-gen: harness/fit_model.py)
// Equivalent to model/ldo_model.lib (validated in ngspice). NO laplace_nd.
//   Zout = (R_a + sL_a||R_pl) || (R_b+sL_b) || (ESR+1/sCout) ; R_pl damps L
//   PSRR = i_c*Zout, i_c = G0 + sum Gi/(1+s/wi) [real bank] + one signed COMPLEX 2nd-
//          order section (b0+b1 s)/(1+s/(Q w0)+(s/w0)^2) -> non-min-phase / notch PHASE
//          (V4/V3). LP filter resistors are noiseless conductances (no thermal noise).
//   Noise= DECOUPLED Norton @vout: white-R + 6 R||C-Lorentzian current sections,
//          transconducted into vout (gm sets amplitude) -> In*|Zout| = Sv. pnoise/hbnoise.
//   slew_en=1 : nonlinear DC-curve branch (current-limit + dropout), INLINE PWL
// Ports: vin vout gnd (explicit ground -- no global-ground references inside).
// Instance params: iload, slew_en, vdd (supply DC ref + dc_linereg Vout tracking),
//   voutdc (>0 pins Vout DC; 0 = characterized). Defaults = characterized behavior.
// Params interpolated as quadratics in ln(iload) through corners {20u,121u,250u}.
// ============================================================
`include "constants.vams"
`include "disciplines.vams"

module ldo_model(vin, vout, gnd);
  inout vin, vout, gnd;
  electrical vin, vout, gnd, vrg, nA, nC, nbb, np1, np2, np3, vrf, ncs1, ncs2, nw, nk1, nk2, nk3, nk4, nk5, nk6;

  parameter real iload   = 1.210000e-04 from (0:inf);
  parameter integer slew_en = 0 from [0:1];
  parameter real vdd    = 1.05;   // supply DC operating point [V]: PSRR DC reference
                                    // + dc_linereg Vout-DC tracking (clamped to the
                                    // characterized span [0.9,1.3]V)
  parameter real voutdc = 0 from [0:inf);   // >0: pin Vout DC at this iload [V]
                                            // (0 = characterized DC; small-signal unchanged)
  parameter real Cout = 9.969315e-10;   // auto-extracted physical output cap
  parameter real ESR  = 5.000093e-01;   // auto-extracted physical ESR
  parameter real VREG121 = 9.011242e-01;
  parameter real NRk = 1.000000e+06;   // fixed noise-section resistor (gm sets amplitude)
  parameter real Cn1 = 8.588995e-09;   // corner 18.53 Hz
  parameter real Cn2 = 6.072694e-10;   // corner 262.1 Hz
  parameter real Cn3 = 4.191329e-11;   // corner 3797 Hz
  parameter real Cn4 = 4.053907e-13;   // corner 3.926e+05 Hz
  parameter real Cn5 = 2.027003e-13;   // corner 7.852e+05 Hz
  parameter real Cn6 = 2.090802e-15;   // corner 7.612e+07 Hz

  real u, ic, R_a, L_a, R_pl, R_b, L_b, G0, G1, w1, G2, w2, G3, w3, gnw, gn1, gn2, gn3, gn4, gn5, gn6, vreg, Cps;
  real pcb0, pcb1, pcw0, pcq, pca1, pca2, Rpc, Lpc, Cpc, gqb1;
  real vddc, lrsh, vregeff, vdrp;

  analog begin
    @(initial_step) begin
      ic = min(max(iload, 2.000000e-05), 2.500000e-04);
      u  = ln(ic);
      R_a = min(max(exp((1.836710e-01)*u*u + (2.900097e+00)*u + (1.429951e+01)),1.774208e+01),8.376544e+01);
      L_a = min(max(exp((1.396641e-01)*u*u + (2.061160e+00)*u + (-4.541689e+00)),5.936622e-06),2.787298e-05);
      R_pl = min(max(exp((2.332657e-13)*u*u + (4.518403e-12)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      R_b = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      L_b = min(max(exp((6.069877e-16)*u*u + (6.085391e-15)*u + (-2.763102e+01)),9.950249e-13),1.005000e-12);
      G0 = min(max((1.955015e-04)*u*u + (4.609397e-03)*u + (2.746233e-02),4.655433e-04),2.691572e-03);
      G1 = min(max((4.386092e-05)*u*u + (2.757975e-04)*u + (-2.593843e-03),-1.871177e-03),-4.361133e-04);
      w1 = min(max(exp((3.844910e-02)*u*u + (7.335623e-01)*u + (1.840398e+01)),2.989163e+06),3.182342e+06);
      G2 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      w2 = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      G3 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      w3 = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      pcb0 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      pcb1 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      pcw0 = min(max(exp((4.717895e-16)*u*u + (1.054077e-14)*u + (1.219951e+01)),1.977032e+05),1.996852e+05);
      pcq = min(max(exp((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00)),9.950249e-01),1.005000e+00);
      gnw = min(max(exp((-5.816257e-02)*u*u + (-1.163303e+00)*u + (-1.419655e+01)),1.927479e-04),2.217763e-04);
      gn1 = min(max(exp((-1.880571e-01)*u*u + (-2.987837e+00)*u + (-1.143675e+01)),3.232263e-01),1.511066e+00);
      gn2 = min(max(exp((-1.836635e-01)*u*u + (-2.904064e+00)*u + (-1.244267e+01)),7.986837e-02),3.731874e-01);
      gn3 = min(max(exp((-2.029024e-01)*u*u + (-3.270874e+00)*u + (-1.545121e+01)),2.194172e-02),1.027614e-01);
      gn4 = min(max(exp((-1.691179e-01)*u*u + (-2.625159e+00)*u + (-1.304568e+01)),1.173413e-02),5.495036e-02);
      gn5 = min(max(exp((2.098653e+00)*u*u + (3.828265e+01)*u + (1.616939e+02)),2.565785e-06),1.084506e-03);
      gn6 = min(max(exp((-8.941417e-02)*u*u + (-1.873140e+00)*u + (-2.762052e+01)),1.197424e-08),1.830523e-08);
      vreg = min(max((2.001640e-04)*u*u + (2.411893e-03)*u + (9.065944e-01),9.003417e-01),9.039489e-01);
      Cps = 1e-12;
      // complex PSRR section: a1=1/(Q.w0), a2=1/w0^2 ; series R-L-C (Cpc fixed)
      Cpc = 1e-12;
      pca1 = 1.0/(pcq*pcw0); pca2 = 1.0/(pcw0*pcw0);
      Rpc = pca1/Cpc; Lpc = pca2/Cpc; gqb1 = pcb1/pca1;
      // R3-L1: vdd line-reg DC shift (characterized dc_linereg poly) / voutdc override
      vddc = min(max(vdd, 9.000000e-01), 1.300000e+00);
      lrsh = (-9.641010e+00)*vddc*vddc*vddc*vddc + (4.378899e+01)*vddc*vddc*vddc + (-7.433767e+01)*vddc*vddc + (5.590457e+01)*vddc + (-1.481593e+01) - (8.991185e-01);
      vregeff = (voutdc > 0) ? voutdc + R_a*ic : vreg + lrsh;
    end

    // ---- references / DC operating point ----
    V(vrf, gnd) <+ vdd;              // supply DC reference (settable; no DC coupling)
    V(vrg, gnd) <+ vregeff;          // regulated output reference (incl. R3-L1 shift)

    // ---- Zout branch C: series Cout + ESR (vout -> vrg) ----
    I(vout, nC) <+ Cout*ddt(V(vout, nC));
    V(nC, vrg)  <+ ESR*I(nC, vrg);

    // ---- Zout branch B: optional 2nd R-L (R_b->inf disables it) ----
    I(vout, nbb) <+ idt(V(vout, nbb))/L_b;
    V(nbb, vrg)  <+ R_b*I(nbb, vrg);

    // ---- Zout branch A: (L_a || R_pl) + (R_a | nonlinear dropout) ----
    // L_a||R_pl as summed current contributions (idt form admits the parallel R)
    I(vout, nA) <+ idt(V(vout, nA))/L_a + V(vout, nA)/R_pl;
    if (slew_en == 0)
      V(nA, vrg) <+ R_a*I(nA, vrg);
    else begin
      // nonlinear DC-curve branch (current-limit + dropout): INLINE closed-form PWL of
      // the characterized (Vdrop, Iload) table -- i = i1 + g1*(v-v1) + sum dg_k*max(v-v_k,0)
      // == 1-D linear table interpolation, linear end extrapolation. Self-contained
      // (no external table file -> no run-dir path issues; OpenVAF-compilable, R8 closed).
      vdrp = V(vrg, nA) - (vregeff - VREG121);
      I(vrg, nA) <+ (1.000000e-06) + (3.394369e-03)*(vdrp-(-5.378096e-03)) + (7.626646e-03)*max(vdrp-(-1.842829e-03),0) + (5.796378e-03)*max(vdrp-(-7.539995e-04),0) + (5.012260e-03)*max(vdrp-(-4.045254e-05),0)
                       + (4.397047e-03)*max(vdrp-(5.092585e-04),0) + (3.883882e-03)*max(vdrp-(9.668075e-04),0) + (3.442807e-03)*max(vdrp-(1.365338e-03),0) + (3.056422e-03)*max(vdrp-(1.722977e-03),0)
                       + (2.712922e-03)*max(vdrp-(2.050758e-03),0) + (2.404498e-03)*max(vdrp-(2.355925e-03),0) + (2.125848e-03)*max(vdrp-(2.643507e-03),0) + (1.873402e-03)*max(vdrp-(2.917148e-03),0)
                       + (1.644435e-03)*max(vdrp-(3.179578e-03),0) + (1.436358e-03)*max(vdrp-(3.432898e-03),0) + (1.247997e-03)*max(vdrp-(3.678763e-03),0) + (1.077317e-03)*max(vdrp-(3.918498e-03),0)
                       + (9.240856e-04)*max(vdrp-(4.153182e-03),0) + (7.853476e-04)*max(vdrp-(4.383700e-03),0) + (6.620508e-04)*max(vdrp-(4.610792e-03),0) + (5.504703e-04)*max(vdrp-(4.835074e-03),0)
                       + (4.515205e-04)*max(vdrp-(5.057072e-03),0) + (3.636230e-04)*max(vdrp-(5.277231e-03),0) + (2.844714e-04)*max(vdrp-(5.495931e-03),0) + (2.145304e-04)*max(vdrp-(5.713503e-03),0)
                       + (1.529394e-04)*max(vdrp-(5.930232e-03),0) + (9.701584e-05)*max(vdrp-(6.146364e-03),0) + (4.876429e-05)*max(vdrp-(6.362119e-03),0) + (4.648678e-06)*max(vdrp-(6.577685e-03),0)
                       + (-3.381432e-05)*max(vdrp-(6.793233e-03),0) + (-6.827758e-05)*max(vdrp-(7.008912e-03),0) + (-9.915410e-05)*max(vdrp-(7.224856e-03),0) + (-1.266369e-04)*max(vdrp-(7.441186e-03),0)
                       + (-1.514570e-04)*max(vdrp-(7.658011e-03),0) + (-1.730909e-04)*max(vdrp-(7.875431e-03),0) + (-1.938098e-04)*max(vdrp-(8.093535e-03),0) + (-2.118436e-04)*max(vdrp-(8.312410e-03),0)
                       + (-2.284586e-04)*max(vdrp-(8.532134e-03),0) + (-2.441486e-04)*max(vdrp-(8.752781e-03),0) + (-2.584238e-04)*max(vdrp-(8.974423e-03),0) + (-2.722601e-04)*max(vdrp-(9.197128e-03),0)
                       + (-2.851670e-04)*max(vdrp-(9.420964e-03),0) + (3.578365e-04)*max(vdrp-(9.645997e-03),0) + (-9.450441e-04)*max(vdrp-(9.795019e-03),0) + (-5.432412e-04)*max(vdrp-(1.017425e-02),0)
                       + (-5.768318e-04)*max(vdrp-(1.055743e-02),0) + (-6.121363e-04)*max(vdrp-(1.094489e-02),0) + (-6.503318e-04)*max(vdrp-(1.133700e-02),0) + (-6.923572e-04)*max(vdrp-(1.173417e-02),0)
                       + (-7.397272e-04)*max(vdrp-(1.213688e-02),0) + (-7.939984e-04)*max(vdrp-(1.254568e-02),0) + (-8.569619e-04)*max(vdrp-(1.296123e-02),0) + (-9.304019e-04)*max(vdrp-(1.338430e-02),0)
                       + (-1.017051e-03)*max(vdrp-(1.381588e-02),0) + (-1.119727e-03)*max(vdrp-(1.425713e-02),0) + (-1.242184e-03)*max(vdrp-(1.470956e-02),0) + (-1.387894e-03)*max(vdrp-(1.517508e-02),0)
                       + (-1.561055e-03)*max(vdrp-(1.565613e-02),0) + (-1.765077e-03)*max(vdrp-(1.615595e-02),0) + (-2.000962e-03)*max(vdrp-(1.667883e-02),0) + (-2.264815e-03)*max(vdrp-(1.723058e-02),0)
                       + (-2.543190e-03)*max(vdrp-(1.781910e-02),0) + (-2.808520e-03)*max(vdrp-(1.845523e-02),0) + (-3.015054e-03)*max(vdrp-(1.915375e-02),0) + (-3.103950e-03)*max(vdrp-(1.993449e-02),0)
                       + (-3.021978e-03)*max(vdrp-(2.082287e-02),0) + (-2.751530e-03)*max(vdrp-(2.184899e-02),0) + (-2.332775e-03)*max(vdrp-(2.304378e-02),0) + (-1.852296e-03)*max(vdrp-(2.443204e-02),0)
                       + (-1.400378e-03)*max(vdrp-(2.602513e-02),0) + (-1.031311e-03)*max(vdrp-(2.781822e-02),0) + (-7.560195e-04)*max(vdrp-(2.979401e-02),0) + (-5.600310e-04)*max(vdrp-(3.192926e-02),0)
                       + (-4.225215e-04)*max(vdrp-(3.420031e-02),0) + (-3.256190e-04)*max(vdrp-(3.658581e-02),0) + (-2.564047e-04)*max(vdrp-(3.906770e-02),0) + (-2.060781e-04)*max(vdrp-(4.163115e-02),0)
                       + (-1.687923e-04)*max(vdrp-(4.426415e-02),0) + (-1.406640e-04)*max(vdrp-(4.695699e-02),0) + (-1.190643e-04)*max(vdrp-(4.970182e-02),0) + (-1.022191e-04)*max(vdrp-(5.249224e-02),0)
                       + (-8.888188e-05)*max(vdrp-(5.532303e-02),0) + (-7.817109e-05)*max(vdrp-(5.818989e-02),0) + (-6.947687e-05)*max(vdrp-(6.108924e-02),0) + (-6.232530e-05)*max(vdrp-(6.401809e-02),0)
                       + (-5.639289e-05)*max(vdrp-(6.697391e-02),0) + (-5.141751e-05)*max(vdrp-(6.995458e-02),0) + (-4.721266e-05)*max(vdrp-(7.295826e-02),0) + (-4.362681e-05)*max(vdrp-(7.598340e-02),0)
                       + (-4.054858e-05)*max(vdrp-(7.902863e-02),0) + (-3.788723e-05)*max(vdrp-(8.209277e-02),0) + (-3.557625e-05)*max(vdrp-(8.517481e-02),0) + (-3.354825e-05)*max(vdrp-(8.827384e-02),0)
                       + (-3.177117e-05)*max(vdrp-(9.138906e-02),0) + (-3.019522e-05)*max(vdrp-(9.451977e-02),0) + (-2.879964e-05)*max(vdrp-(9.766535e-02),0) + (-2.755322e-05)*max(vdrp-(1.008252e-01),0)
                       + (-2.643632e-05)*max(vdrp-(1.039990e-01),0) + (-2.543626e-05)*max(vdrp-(1.071860e-01),0) + (-2.453338e-05)*max(vdrp-(1.103861e-01),0) + (-2.371853e-05)*max(vdrp-(1.135988e-01),0)
                       + (-2.297543e-05)*max(vdrp-(1.168237e-01),0) + (-2.230747e-05)*max(vdrp-(1.200606e-01),0) + (-2.169351e-05)*max(vdrp-(1.233093e-01),0) + (-2.113380e-05)*max(vdrp-(1.265695e-01),0)
                       + (-2.062676e-05)*max(vdrp-(1.298409e-01),0) + (-2.015800e-05)*max(vdrp-(1.331234e-01),0) + (-1.973012e-05)*max(vdrp-(1.364168e-01),0) + (-1.934023e-05)*max(vdrp-(1.397209e-01),0)
                       + (-1.897827e-05)*max(vdrp-(1.430357e-01),0) + (-1.864715e-05)*max(vdrp-(1.463609e-01),0) + (-1.834965e-05)*max(vdrp-(1.496964e-01),0) + (-1.806720e-05)*max(vdrp-(1.530421e-01),0)
                       + (-1.781710e-05)*max(vdrp-(1.563981e-01),0) + (-1.758454e-05)*max(vdrp-(1.597640e-01),0) + (-1.737435e-05)*max(vdrp-(1.631400e-01),0) + (-1.718082e-05)*max(vdrp-(1.665259e-01),0)
                       + (-1.701046e-05)*max(vdrp-(1.699216e-01),0) + (-1.685591e-05)*max(vdrp-(1.733273e-01),0) + (-1.671681e-05)*max(vdrp-(1.767427e-01),0) + (-1.659790e-05)*max(vdrp-(1.801678e-01),0)
