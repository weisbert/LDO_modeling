// ============================================================
// Behavioral LDO model for Cadence Spectre  (auto-gen: harness/fit_model.py)
// Equivalent to model/ldo_model.lib (validated in ngspice). NO laplace_nd.
//   Zout = (R_a + sL_a||R_pl) || (R_b+sL_b) || (ESR+1/sCout) ; R_pl damps L
//   PSRR = i_c*Zout, i_c = G0 + sum Gi/(1+s/wi) [real bank] + one signed COMPLEX 2nd-
//          order section (b0+b1 s)/(1+s/(Q w0)+(s/w0)^2) -> non-min-phase / notch PHASE
//          (V4/V3). LP filter resistors are noiseless conductances (no thermal noise).
//   Noise= DECOUPLED Norton @vout: white-R + 6 R||C-Lorentzian current sections,
//          transconducted into vout (gm sets amplitude) -> In*|Zout| = Sv. pnoise/hbnoise.
//   slew_en=1 : nonlinear DC-curve branch (current-limit + dropout), INLINE PWL
// Ports: vin vout gnd (explicit ground -- no global-ground references inside).
// Instance params: iload, slew_en, vdd (supply DC ref + dc_linereg Vout tracking),
//   voutdc (>0 pins Vout DC; 0 = characterized). Defaults = characterized behavior.
// Params interpolated as quadratics in ln(iload) through corners {20u,121u,250u}.
// ============================================================
`include "constants.vams"
`include "disciplines.vams"

module ldo_model(vin, vout, gnd);
  inout vin, vout, gnd;
  electrical vin, vout, gnd, vrg, nA, nC, nbb, np1, np2, np3, vrf, ncs1, ncs2, nw, nk1, nk2, nk3, nk4, nk5, nk6;

  parameter real iload   = 1.210000e-04 from (0:inf);
  parameter integer slew_en = 0 from [0:1];
  parameter real vdd    = 1.05;   // supply DC operating point [V]: PSRR DC reference
                                    // + dc_linereg Vout-DC tracking (clamped to the
                                    // characterized span [0.9,1.3]V)
  parameter real voutdc = 0 from [0:inf);   // >0: pin Vout DC at this iload [V]
                                            // (0 = characterized DC; small-signal unchanged)
  parameter real Cout = 9.979136e-10;   // auto-extracted physical output cap
  parameter real ESR  = 5.045151e-01;   // auto-extracted physical ESR
  parameter real VREG121 = 9.011222e-01;
  parameter real NRk = 1.000000e+06;   // fixed noise-section resistor (gm sets amplitude)
  parameter real Cn1 = 8.600675e-09;   // corner 18.5 Hz
  parameter real Cn2 = 6.092649e-10;   // corner 261.2 Hz
  parameter real Cn3 = 4.216820e-11;   // corner 3774 Hz
  parameter real Cn4 = 4.077992e-13;   // corner 3.903e+05 Hz
  parameter real Cn5 = 2.039064e-13;   // corner 7.805e+05 Hz
  parameter real Cn6 = 3.558243e-15;   // corner 4.473e+07 Hz

  real u, ic, R_a, L_a, R_pl, R_b, L_b, G0, G1, w1, G2, w2, G3, w3, gnw, gn1, gn2, gn3, gn4, gn5, gn6, vreg, Cps;
  real pcb0, pcb1, pcw0, pcq, pca1, pca2, Rpc, Lpc, Cpc, gqb1;
  real vddc, lrsh, vregeff, vdrp;

  analog begin
    @(initial_step) begin
      ic = min(max(iload, 2.000000e-05), 2.500000e-04);
      u  = ln(ic);
      R_a = min(max(exp((1.836558e-01)*u*u + (2.899843e+00)*u + (1.429769e+01)),1.772851e+01),8.369359e+01);
      L_a = min(max(exp((1.397007e-01)*u*u + (2.061810e+00)*u + (-4.539550e+00)),5.932287e-06),2.785615e-05);
      R_pl = min(max(exp((-1.730472e-12)*u*u + (-2.940635e-11)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      R_b = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      L_b = min(max(exp((6.069877e-16)*u*u + (6.085391e-15)*u + (-2.763102e+01)),9.950249e-13),1.005000e-12);
      G0 = min(max((1.902512e-04)*u*u + (4.488688e-03)*u + (2.676013e-02),4.550078e-04),2.629108e-03);
      G1 = min(max((4.900041e-05)*u*u + (3.942973e-04)*u + (-1.902566e-03),-1.808936e-03),-4.255662e-04);
      w1 = min(max(exp((3.510447e-02)*u*u + (6.656448e-01)*u + (1.803510e+01)),2.905505e+06),3.101986e+06);
      G2 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      w2 = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      G3 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      w3 = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      pcb0 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      pcb1 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      pcw0 = min(max(exp((4.717895e-16)*u*u + (1.054077e-14)*u + (1.219951e+01)),1.977032e+05),1.996852e+05);
      pcq = min(max(exp((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00)),9.950249e-01),1.005000e+00);
      gnw = min(max(exp((-6.652013e-02)*u*u + (-1.342871e+00)*u + (-1.516600e+01)),1.824296e-04),2.206812e-04);
      gn1 = min(max(exp((-1.880272e-01)*u*u + (-2.987303e+00)*u + (-1.143318e+01)),3.236463e-01),1.512886e+00);
      gn2 = min(max(exp((-1.837116e-01)*u*u + (-2.905016e+00)*u + (-1.244531e+01)),8.003142e-02),3.739173e-01);
      gn3 = min(max(exp((-2.025709e-01)*u*u + (-3.264591e+00)*u + (-1.541873e+01)),2.201458e-02),1.030887e-01);
      gn4 = min(max(exp((-1.698009e-01)*u*u + (-2.637650e+00)*u + (-1.310066e+01)),1.173661e-02),5.504027e-02);
      gn5 = min(max(exp((1.716220e+00)*u*u + (3.068251e+01)*u + (1.243842e+02)),2.917659e-06),1.262128e-03);
      gn6 = min(max(exp((-2.187713e-01)*u*u + (-4.383716e+00)*u + (-3.976301e+01)),9.626063e-09),1.620062e-08);
      vreg = min(max((1.995509e-04)*u*u + (2.399391e-03)*u + (9.065295e-01),9.003383e-01),9.039474e-01);
      Cps = 1e-12;
      // complex PSRR section: a1=1/(Q.w0), a2=1/w0^2 ; series R-L-C (Cpc fixed)
      Cpc = 1e-12;
      pca1 = 1.0/(pcq*pcw0); pca2 = 1.0/(pcw0*pcw0);
      Rpc = pca1/Cpc; Lpc = pca2/Cpc; gqb1 = pcb1/pca1;
      // R3-L1: vdd line-reg DC shift (characterized dc_linereg poly) / voutdc override
      vddc = min(max(vdd, 9.000000e-01), 1.300000e+00);
      lrsh = (-9.641010e+00)*vddc*vddc*vddc*vddc + (4.378899e+01)*vddc*vddc*vddc + (-7.433767e+01)*vddc*vddc + (5.590457e+01)*vddc + (-1.481593e+01) - (8.991185e-01);
      vregeff = (voutdc > 0) ? voutdc + R_a*ic : vreg + lrsh;
    end

    // ---- references / DC operating point ----
    V(vrf, gnd) <+ vdd;              // supply DC reference (settable; no DC coupling)
    V(vrg, gnd) <+ vregeff;          // regulated output reference (incl. R3-L1 shift)

    // ---- Zout branch C: series Cout + ESR (vout -> vrg) ----
    I(vout, nC) <+ Cout*ddt(V(vout, nC));
    V(nC, vrg)  <+ ESR*I(nC, vrg);

    // ---- Zout branch B: optional 2nd R-L (R_b->inf disables it) ----
    I(vout, nbb) <+ idt(V(vout, nbb))/L_b;
    V(nbb, vrg)  <+ R_b*I(nbb, vrg);

    // ---- Zout branch A: (L_a || R_pl) + (R_a | nonlinear dropout) ----
    // L_a||R_pl as summed current contributions (idt form admits the parallel R)
    I(vout, nA) <+ idt(V(vout, nA))/L_a + V(vout, nA)/R_pl;
    if (slew_en == 0)
      V(nA, vrg) <+ R_a*I(nA, vrg);
    else begin
      // nonlinear DC-curve branch (current-limit + dropout): INLINE closed-form PWL of
      // the characterized (Vdrop, Iload) table -- i = i1 + g1*(v-v1) + sum dg_k*max(v-v_k,0)
      // == 1-D linear table interpolation, linear end extrapolation. Self-contained
      // (no external table file -> no run-dir path issues; OpenVAF-compilable, R8 closed).
      vdrp = V(vrg, nA) - (vregeff - VREG121);
      I(vrg, nA) <+ (1.000000e-06) + (3.394369e-03)*(vdrp-(-5.380136e-03)) + (7.626646e-03)*max(vdrp-(-1.844869e-03),0) + (5.796378e-03)*max(vdrp-(-7.560400e-04),0) + (5.012260e-03)*max(vdrp-(-4.249304e-05),0)
                       + (4.397047e-03)*max(vdrp-(5.072180e-04),0) + (3.883882e-03)*max(vdrp-(9.647670e-04),0) + (3.442807e-03)*max(vdrp-(1.363298e-03),0) + (3.056422e-03)*max(vdrp-(1.720937e-03),0)
                       + (2.712922e-03)*max(vdrp-(2.048718e-03),0) + (2.404498e-03)*max(vdrp-(2.353885e-03),0) + (2.125848e-03)*max(vdrp-(2.641467e-03),0) + (1.873402e-03)*max(vdrp-(2.915108e-03),0)
                       + (1.644435e-03)*max(vdrp-(3.177538e-03),0) + (1.436358e-03)*max(vdrp-(3.430858e-03),0) + (1.247997e-03)*max(vdrp-(3.676723e-03),0) + (1.077317e-03)*max(vdrp-(3.916458e-03),0)
                       + (9.240856e-04)*max(vdrp-(4.151142e-03),0) + (7.853476e-04)*max(vdrp-(4.381660e-03),0) + (6.620508e-04)*max(vdrp-(4.608752e-03),0) + (5.504703e-04)*max(vdrp-(4.833034e-03),0)
                       + (4.515205e-04)*max(vdrp-(5.055032e-03),0) + (3.636230e-04)*max(vdrp-(5.275191e-03),0) + (2.844714e-04)*max(vdrp-(5.493891e-03),0) + (2.145304e-04)*max(vdrp-(5.711463e-03),0)
                       + (1.529394e-04)*max(vdrp-(5.928192e-03),0) + (9.701584e-05)*max(vdrp-(6.144324e-03),0) + (4.876429e-05)*max(vdrp-(6.360079e-03),0) + (4.648678e-06)*max(vdrp-(6.575645e-03),0)
                       + (-3.381432e-05)*max(vdrp-(6.791193e-03),0) + (-6.827758e-05)*max(vdrp-(7.006872e-03),0) + (-9.915410e-05)*max(vdrp-(7.222816e-03),0) + (-1.266369e-04)*max(vdrp-(7.439146e-03),0)
                       + (-1.514570e-04)*max(vdrp-(7.655971e-03),0) + (-1.730909e-04)*max(vdrp-(7.873391e-03),0) + (-1.938098e-04)*max(vdrp-(8.091495e-03),0) + (-2.118436e-04)*max(vdrp-(8.310370e-03),0)
                       + (-2.284586e-04)*max(vdrp-(8.530094e-03),0) + (-2.441486e-04)*max(vdrp-(8.750741e-03),0) + (-2.584238e-04)*max(vdrp-(8.972383e-03),0) + (-2.722601e-04)*max(vdrp-(9.195088e-03),0)
                       + (-2.851670e-04)*max(vdrp-(9.418924e-03),0) + (3.578365e-04)*max(vdrp-(9.643957e-03),0) + (-9.450441e-04)*max(vdrp-(9.792979e-03),0) + (-5.432412e-04)*max(vdrp-(1.017221e-02),0)
                       + (-5.768318e-04)*max(vdrp-(1.055539e-02),0) + (-6.121363e-04)*max(vdrp-(1.094285e-02),0) + (-6.503318e-04)*max(vdrp-(1.133496e-02),0) + (-6.923572e-04)*max(vdrp-(1.173213e-02),0)
                       + (-7.397272e-04)*max(vdrp-(1.213484e-02),0) + (-7.939984e-04)*max(vdrp-(1.254364e-02),0) + (-8.569619e-04)*max(vdrp-(1.295919e-02),0) + (-9.304019e-04)*max(vdrp-(1.338226e-02),0)
                       + (-1.017051e-03)*max(vdrp-(1.381383e-02),0) + (-1.119727e-03)*max(vdrp-(1.425509e-02),0) + (-1.242184e-03)*max(vdrp-(1.470752e-02),0) + (-1.387894e-03)*max(vdrp-(1.517303e-02),0)
                       + (-1.561055e-03)*max(vdrp-(1.565409e-02),0) + (-1.765077e-03)*max(vdrp-(1.615391e-02),0) + (-2.000962e-03)*max(vdrp-(1.667679e-02),0) + (-2.264815e-03)*max(vdrp-(1.722854e-02),0)
                       + (-2.543190e-03)*max(vdrp-(1.781706e-02),0) + (-2.808520e-03)*max(vdrp-(1.845319e-02),0) + (-3.015054e-03)*max(vdrp-(1.915171e-02),0) + (-3.103950e-03)*max(vdrp-(1.993245e-02),0)
                       + (-3.021978e-03)*max(vdrp-(2.082083e-02),0) + (-2.751530e-03)*max(vdrp-(2.184695e-02),0) + (-2.332775e-03)*max(vdrp-(2.304174e-02),0) + (-1.852296e-03)*max(vdrp-(2.443000e-02),0)
                       + (-1.400378e-03)*max(vdrp-(2.602308e-02),0) + (-1.031311e-03)*max(vdrp-(2.781618e-02),0) + (-7.560195e-04)*max(vdrp-(2.979197e-02),0) + (-5.600310e-04)*max(vdrp-(3.192722e-02),0)
                       + (-4.225215e-04)*max(vdrp-(3.419827e-02),0) + (-3.256190e-04)*max(vdrp-(3.658377e-02),0) + (-2.564047e-04)*max(vdrp-(3.906565e-02),0) + (-2.060781e-04)*max(vdrp-(4.162911e-02),0)
                       + (-1.687923e-04)*max(vdrp-(4.426211e-02),0) + (-1.406640e-04)*max(vdrp-(4.695495e-02),0) + (-1.190643e-04)*max(vdrp-(4.969977e-02),0) + (-1.022191e-04)*max(vdrp-(5.249020e-02),0)
                       + (-8.888188e-05)*max(vdrp-(5.532099e-02),0) + (-7.817109e-05)*max(vdrp-(5.818785e-02),0) + (-6.947687e-05)*max(vdrp-(6.108720e-02),0) + (-6.232530e-05)*max(vdrp-(6.401605e-02),0)
                       + (-5.639289e-05)*max(vdrp-(6.697187e-02),0) + (-5.141751e-05)*max(vdrp-(6.995254e-02),0) + (-4.721266e-05)*max(vdrp-(7.295622e-02),0) + (-4.362681e-05)*max(vdrp-(7.598136e-02),0)
                       + (-4.054858e-05)*max(vdrp-(7.902658e-02),0) + (-3.788723e-05)*max(vdrp-(8.209073e-02),0) + (-3.557625e-05)*max(vdrp-(8.517277e-02),0) + (-3.354825e-05)*max(vdrp-(8.827180e-02),0)
                       + (-3.177117e-05)*max(vdrp-(9.138702e-02),0) + (-3.019522e-05)*max(vdrp-(9.451773e-02),0) + (-2.879964e-05)*max(vdrp-(9.766331e-02),0) + (-2.755322e-05)*max(vdrp-(1.008232e-01),0)
                       + (-2.643632e-05)*max(vdrp-(1.039969e-01),0) + (-2.543626e-05)*max(vdrp-(1.071840e-01),0) + (-2.453338e-05)*max(vdrp-(1.103841e-01),0) + (-2.371853e-05)*max(vdrp-(1.135967e-01),0)
                       + (-2.297543e-05)*max(vdrp-(1.168217e-01),0) + (-2.230747e-05)*max(vdrp-(1.200586e-01),0) + (-2.169351e-05)*max(vdrp-(1.233073e-01),0) + (-2.113380e-05)*max(vdrp-(1.265674e-01),0)
                       + (-2.062676e-05)*max(vdrp-(1.298389e-01),0) + (-2.015800e-05)*max(vdrp-(1.331214e-01),0) + (-1.973012e-05)*max(vdrp-(1.364148e-01),0) + (-1.934023e-05)*max(vdrp-(1.397189e-01),0)
                       + (-1.897827e-05)*max(vdrp-(1.430336e-01),0) + (-1.864715e-05)*max(vdrp-(1.463588e-01),0) + (-1.834965e-05)*max(vdrp-(1.496943e-01),0) + (-1.806720e-05)*max(vdrp-(1.530401e-01),0)
                       + (-1.781710e-05)*max(vdrp-(1.563960e-01),0) + (-1.758454e-05)*max(vdrp-(1.597620e-01),0) + (-1.737435e-05)*max(vdrp-(1.631379e-01),0) + (-1.718082e-05)*max(vdrp-(1.665238e-01),0)
