                       + (-3.609219e-06)*max(vdrp-(1.421468e+00),0) + (-3.356624e-06)*max(vdrp-(1.448963e+00),0) + (-3.119874e-06)*max(vdrp-(1.476585e+00),0) + (-2.897755e-06)*max(vdrp-(1.504327e+00),0)
                       + (-2.689412e-06)*max(vdrp-(1.532181e+00),0) + (-2.493867e-06)*max(vdrp-(1.560139e+00),0) + (-2.310225e-06)*max(vdrp-(1.588196e+00),0) + (-2.137759e-06)*max(vdrp-(1.616344e+00),0)
                       + (-1.975630e-06)*max(vdrp-(1.644576e+00),0) + (-1.823202e-06)*max(vdrp-(1.672888e+00),0) + (-1.679841e-06)*max(vdrp-(1.701273e+00),0) + (-1.544931e-06)*max(vdrp-(1.729725e+00),0)
                       + (-1.417870e-06)*max(vdrp-(1.758241e+00),0) + (-1.298190e-06)*max(vdrp-(1.786814e+00),0) + (-1.185452e-06)*max(vdrp-(1.815440e+00),0) + (-1.079098e-06)*max(vdrp-(1.844115e+00),0)
                       + (-9.786941e-07)*max(vdrp-(1.872834e+00),0) + (-8.844283e-07)*max(vdrp-(1.901594e+00),0) + (-7.945286e-07)*max(vdrp-(1.930390e+00),0) + (-7.103532e-07)*max(vdrp-(1.959219e+00),0)
                       + (-6.305246e-07)*max(vdrp-(1.988078e+00),0) + (-5.549568e-07)*max(vdrp-(2.016963e+00),0) + (-4.838124e-07)*max(vdrp-(2.045872e+00),0) + (-4.163064e-07)*max(vdrp-(2.074800e+00),0)
                       + (-3.521430e-07)*max(vdrp-(2.103746e+00),0) + (-2.915106e-07)*max(vdrp-(2.132707e+00),0) + (-2.343647e-07)*max(vdrp-(2.161680e+00),0) + (-1.797146e-07)*max(vdrp-(2.190663e+00),0)
                       + (-1.282423e-07)*max(vdrp-(2.219653e+00),0) + (-7.944350e-08)*max(vdrp-(2.248649e+00),0) + (-3.234301e-08)*max(vdrp-(2.277648e+00),0) + (1.117702e-08)*max(vdrp-(2.306648e+00),0)
                       + (5.351203e-08)*max(vdrp-(2.335648e+00),0) + (9.301177e-08)*max(vdrp-(2.364646e+00),0) + (1.313535e-07)*max(vdrp-(2.393640e+00),0) + (1.671196e-07)*max(vdrp-(2.422628e+00),0)
