                       + (-8.389836e-06)*max(vdrp-(1.104858e+00),0) + (-7.827816e-06)*max(vdrp-(1.130071e+00),0) + (-7.303472e-06)*max(vdrp-(1.155535e+00),0) + (-6.813635e-06)*max(vdrp-(1.181238e+00),0)
