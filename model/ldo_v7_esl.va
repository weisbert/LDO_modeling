                       + (6.814865e-07)*max(vdrp-(3.142195e+00),0) + (6.929395e-07)*max(vdrp-(3.170678e+00),0) + (7.029712e-07)*max(vdrp-(3.199132e+00),0) + (7.130591e-07)*max(vdrp-(3.227559e+00),0)
