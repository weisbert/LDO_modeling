                       + (-3.177117e-05)*max(vdrp-(9.157019e-02),0) + (-3.019522e-05)*max(vdrp-(9.470090e-02),0) + (-2.879964e-05)*max(vdrp-(9.784649e-02),0) + (-2.755322e-05)*max(vdrp-(1.010064e-01),0)
                       + (-2.643632e-05)*max(vdrp-(1.041801e-01),0) + (-2.543626e-05)*max(vdrp-(1.073672e-01),0) + (-2.453338e-05)*max(vdrp-(1.105672e-01),0) + (-2.371853e-05)*max(vdrp-(1.137799e-01),0)
                       + (-2.297543e-05)*max(vdrp-(1.170048e-01),0) + (-2.230747e-05)*max(vdrp-(1.202418e-01),0) + (-2.169351e-05)*max(vdrp-(1.234905e-01),0) + (-2.113380e-05)*max(vdrp-(1.267506e-01),0)
                       + (-2.062676e-05)*max(vdrp-(1.300220e-01),0) + (-2.015800e-05)*max(vdrp-(1.333045e-01),0) + (-1.973012e-05)*max(vdrp-(1.365979e-01),0) + (-1.934023e-05)*max(vdrp-(1.399021e-01),0)
                       + (-1.897827e-05)*max(vdrp-(1.432168e-01),0) + (-1.864715e-05)*max(vdrp-(1.465420e-01),0) + (-1.834965e-05)*max(vdrp-(1.498775e-01),0) + (-1.806720e-05)*max(vdrp-(1.532233e-01),0)
                       + (-1.781710e-05)*max(vdrp-(1.565792e-01),0) + (-1.758454e-05)*max(vdrp-(1.599452e-01),0) + (-1.737435e-05)*max(vdrp-(1.633211e-01),0) + (-1.718082e-05)*max(vdrp-(1.667070e-01),0)
