                       + (-3.609219e-06)*max(vdrp-(1.421651e+00),0) + (-3.356624e-06)*max(vdrp-(1.449146e+00),0) + (-3.119874e-06)*max(vdrp-(1.476768e+00),0) + (-2.897755e-06)*max(vdrp-(1.504510e+00),0)
                       + (-2.689412e-06)*max(vdrp-(1.532364e+00),0) + (-2.493867e-06)*max(vdrp-(1.560323e+00),0) + (-2.310225e-06)*max(vdrp-(1.588379e+00),0) + (-2.137759e-06)*max(vdrp-(1.616527e+00),0)
                       + (-1.975630e-06)*max(vdrp-(1.644759e+00),0) + (-1.823202e-06)*max(vdrp-(1.673071e+00),0) + (-1.679841e-06)*max(vdrp-(1.701456e+00),0) + (-1.544931e-06)*max(vdrp-(1.729908e+00),0)
                       + (-1.417870e-06)*max(vdrp-(1.758424e+00),0) + (-1.298190e-06)*max(vdrp-(1.786997e+00),0) + (-1.185452e-06)*max(vdrp-(1.815623e+00),0) + (-1.079098e-06)*max(vdrp-(1.844298e+00),0)
                       + (-9.786941e-07)*max(vdrp-(1.873017e+00),0) + (-8.844283e-07)*max(vdrp-(1.901777e+00),0) + (-7.945286e-07)*max(vdrp-(1.930573e+00),0) + (-7.103532e-07)*max(vdrp-(1.959403e+00),0)
                       + (-6.305246e-07)*max(vdrp-(1.988261e+00),0) + (-5.549568e-07)*max(vdrp-(2.017146e+00),0) + (-4.838124e-07)*max(vdrp-(2.046055e+00),0) + (-4.163064e-07)*max(vdrp-(2.074983e+00),0)
                       + (-3.521430e-07)*max(vdrp-(2.103929e+00),0) + (-2.915106e-07)*max(vdrp-(2.132890e+00),0) + (-2.343647e-07)*max(vdrp-(2.161863e+00),0) + (-1.797146e-07)*max(vdrp-(2.190846e+00),0)
                       + (-1.282423e-07)*max(vdrp-(2.219836e+00),0) + (-7.944350e-08)*max(vdrp-(2.248832e+00),0) + (-3.234301e-08)*max(vdrp-(2.277831e+00),0) + (1.117702e-08)*max(vdrp-(2.306831e+00),0)
                       + (5.351203e-08)*max(vdrp-(2.335831e+00),0) + (9.301177e-08)*max(vdrp-(2.364829e+00),0) + (1.313535e-07)*max(vdrp-(2.393823e+00),0) + (1.671196e-07)*max(vdrp-(2.422811e+00),0)
