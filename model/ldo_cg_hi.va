                       + (6.331160e-07)*max(vdrp-(3.028175e+00),0) + (6.465199e-07)*max(vdrp-(3.056766e+00),0) + (6.585215e-07)*max(vdrp-(3.085330e+00),0) + (6.705875e-07)*max(vdrp-(3.113868e+00),0)
                       + (6.814865e-07)*max(vdrp-(3.142378e+00),0) + (6.929395e-07)*max(vdrp-(3.170861e+00),0) + (7.029712e-07)*max(vdrp-(3.199316e+00),0) + (7.130591e-07)*max(vdrp-(3.227742e+00),0)
