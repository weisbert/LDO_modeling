                       + (-3.177117e-05)*max(vdrp-(9.158333e-02),0) + (-3.019522e-05)*max(vdrp-(9.471405e-02),0) + (-2.879964e-05)*max(vdrp-(9.785963e-02),0) + (-2.755322e-05)*max(vdrp-(1.010195e-01),0)
                       + (-2.643632e-05)*max(vdrp-(1.041932e-01),0) + (-2.543626e-05)*max(vdrp-(1.073803e-01),0) + (-2.453338e-05)*max(vdrp-(1.105804e-01),0) + (-2.371853e-05)*max(vdrp-(1.137930e-01),0)
                       + (-2.297543e-05)*max(vdrp-(1.170180e-01),0) + (-2.230747e-05)*max(vdrp-(1.202549e-01),0) + (-2.169351e-05)*max(vdrp-(1.235036e-01),0) + (-2.113380e-05)*max(vdrp-(1.267638e-01),0)
                       + (-2.062676e-05)*max(vdrp-(1.300352e-01),0) + (-2.015800e-05)*max(vdrp-(1.333177e-01),0) + (-1.973012e-05)*max(vdrp-(1.366111e-01),0) + (-1.934023e-05)*max(vdrp-(1.399152e-01),0)
                       + (-1.897827e-05)*max(vdrp-(1.432299e-01),0) + (-1.864715e-05)*max(vdrp-(1.465551e-01),0) + (-1.834965e-05)*max(vdrp-(1.498907e-01),0) + (-1.806720e-05)*max(vdrp-(1.532364e-01),0)
                       + (-1.781710e-05)*max(vdrp-(1.565923e-01),0) + (-1.758454e-05)*max(vdrp-(1.599583e-01),0) + (-1.737435e-05)*max(vdrp-(1.633343e-01),0) + (-1.718082e-05)*max(vdrp-(1.667202e-01),0)
