                       + (-2.689412e-06)*max(vdrp-(1.532377e+00),0) + (-2.493867e-06)*max(vdrp-(1.560336e+00),0) + (-2.310225e-06)*max(vdrp-(1.588392e+00),0) + (-2.137759e-06)*max(vdrp-(1.616540e+00),0)
                       + (-1.975630e-06)*max(vdrp-(1.644773e+00),0) + (-1.823202e-06)*max(vdrp-(1.673084e+00),0) + (-1.679841e-06)*max(vdrp-(1.701469e+00),0) + (-1.544931e-06)*max(vdrp-(1.729922e+00),0)
                       + (-1.417870e-06)*max(vdrp-(1.758437e+00),0) + (-1.298190e-06)*max(vdrp-(1.787010e+00),0) + (-1.185452e-06)*max(vdrp-(1.815636e+00),0) + (-1.079098e-06)*max(vdrp-(1.844311e+00),0)
                       + (-9.786941e-07)*max(vdrp-(1.873030e+00),0) + (-8.844283e-07)*max(vdrp-(1.901790e+00),0) + (-7.945286e-07)*max(vdrp-(1.930586e+00),0) + (-7.103532e-07)*max(vdrp-(1.959416e+00),0)
