                       + (6.814865e-07)*max(vdrp-(3.142392e+00),0) + (6.929395e-07)*max(vdrp-(3.170874e+00),0) + (7.029712e-07)*max(vdrp-(3.199329e+00),0) + (7.130591e-07)*max(vdrp-(3.227755e+00),0)
