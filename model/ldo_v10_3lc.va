                       + (5.351203e-08)*max(vdrp-(2.335844e+00),0) + (9.301177e-08)*max(vdrp-(2.364842e+00),0) + (1.313535e-07)*max(vdrp-(2.393836e+00),0) + (1.671196e-07)*max(vdrp-(2.422824e+00),0)
