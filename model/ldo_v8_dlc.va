                       + (-8.389836e-06)*max(vdrp-(1.105048e+00),0) + (-7.827816e-06)*max(vdrp-(1.130261e+00),0) + (-7.303472e-06)*max(vdrp-(1.155725e+00),0) + (-6.813635e-06)*max(vdrp-(1.181428e+00),0)
