                       + (6.814865e-07)*max(vdrp-(3.142385e+00),0) + (6.929395e-07)*max(vdrp-(3.170868e+00),0) + (7.029712e-07)*max(vdrp-(3.199322e+00),0) + (7.130591e-07)*max(vdrp-(3.227749e+00),0)
