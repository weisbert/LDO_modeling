                       + (-3.609219e-06)*max(vdrp-(1.421658e+00),0) + (-3.356624e-06)*max(vdrp-(1.449153e+00),0) + (-3.119874e-06)*max(vdrp-(1.476775e+00),0) + (-2.897755e-06)*max(vdrp-(1.504517e+00),0)
                       + (-2.689412e-06)*max(vdrp-(1.532371e+00),0) + (-2.493867e-06)*max(vdrp-(1.560329e+00),0) + (-2.310225e-06)*max(vdrp-(1.588386e+00),0) + (-2.137759e-06)*max(vdrp-(1.616534e+00),0)
                       + (-1.975630e-06)*max(vdrp-(1.644766e+00),0) + (-1.823202e-06)*max(vdrp-(1.673078e+00),0) + (-1.679841e-06)*max(vdrp-(1.701463e+00),0) + (-1.544931e-06)*max(vdrp-(1.729915e+00),0)
                       + (-1.417870e-06)*max(vdrp-(1.758431e+00),0) + (-1.298190e-06)*max(vdrp-(1.787004e+00),0) + (-1.185452e-06)*max(vdrp-(1.815630e+00),0) + (-1.079098e-06)*max(vdrp-(1.844305e+00),0)
                       + (-9.786941e-07)*max(vdrp-(1.873024e+00),0) + (-8.844283e-07)*max(vdrp-(1.901784e+00),0) + (-7.945286e-07)*max(vdrp-(1.930580e+00),0) + (-7.103532e-07)*max(vdrp-(1.959409e+00),0)
                       + (-6.305246e-07)*max(vdrp-(1.988268e+00),0) + (-5.549568e-07)*max(vdrp-(2.017153e+00),0) + (-4.838124e-07)*max(vdrp-(2.046062e+00),0) + (-4.163064e-07)*max(vdrp-(2.074990e+00),0)
                       + (-3.521430e-07)*max(vdrp-(2.103936e+00),0) + (-2.915106e-07)*max(vdrp-(2.132897e+00),0) + (-2.343647e-07)*max(vdrp-(2.161870e+00),0) + (-1.797146e-07)*max(vdrp-(2.190853e+00),0)
                       + (-1.282423e-07)*max(vdrp-(2.219843e+00),0) + (-7.944350e-08)*max(vdrp-(2.248839e+00),0) + (-3.234301e-08)*max(vdrp-(2.277838e+00),0) + (1.117702e-08)*max(vdrp-(2.306838e+00),0)
                       + (5.351203e-08)*max(vdrp-(2.335838e+00),0) + (9.301177e-08)*max(vdrp-(2.364836e+00),0) + (1.313535e-07)*max(vdrp-(2.393830e+00),0) + (1.671196e-07)*max(vdrp-(2.422818e+00),0)
