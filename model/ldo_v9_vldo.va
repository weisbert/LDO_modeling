                       + (-1.652612e-05)*max(vdrp-(1.723497e-01),0) + (-1.651730e-05)*max(vdrp-(1.754655e-01),0) + (-1.651000e-05)*max(vdrp-(1.785892e-01),0) + (-1.650824e-05)*max(vdrp-(1.817211e-01),0)
                       + (-1.650384e-05)*max(vdrp-(1.848610e-01),0) + (-1.650887e-05)*max(vdrp-(1.880092e-01),0) + (-1.651516e-05)*max(vdrp-(1.911655e-01),0) + (-1.652466e-05)*max(vdrp-(1.943300e-01),0)
                       + (-1.653926e-05)*max(vdrp-(1.975029e-01),0) + (-1.655689e-05)*max(vdrp-(2.006841e-01),0) + (-1.657747e-05)*max(vdrp-(2.038737e-01),0) + (-1.660286e-05)*max(vdrp-(2.070718e-01),0)
                       + (-1.663296e-05)*max(vdrp-(2.102784e-01),0) + (-1.666380e-05)*max(vdrp-(2.134935e-01),0) + (-1.670683e-05)*max(vdrp-(2.167173e-01),0) + (-1.674845e-05)*max(vdrp-(2.199498e-01),0)
                       + (-1.679624e-05)*max(vdrp-(2.231911e-01),0) + (-1.685193e-05)*max(vdrp-(2.264412e-01),0) + (-1.691344e-05)*max(vdrp-(2.297002e-01),0) + (-1.698062e-05)*max(vdrp-(2.329683e-01),0)
                       + (-1.705147e-05)*max(vdrp-(2.362454e-01),0) + (-1.713692e-05)*max(vdrp-(2.395318e-01),0) + (-1.722379e-05)*max(vdrp-(2.428274e-01),0) + (-1.732292e-05)*max(vdrp-(2.461323e-01),0)
                       + (-1.743219e-05)*max(vdrp-(2.494468e-01),0) + (-1.754591e-05)*max(vdrp-(2.527709e-01),0) + (-1.767644e-05)*max(vdrp-(2.561047e-01),0) + (-1.781621e-05)*max(vdrp-(2.594483e-01),0)
