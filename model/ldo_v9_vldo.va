                       + (6.810988e-07)*max(vdrp-(3.241334e+00),0) + (6.918168e-07)*max(vdrp-(3.269804e+00),0) + (7.023465e-07)*max(vdrp-(3.298246e+00),0) + (7.124388e-07)*max(vdrp-(3.326660e+00),0)
