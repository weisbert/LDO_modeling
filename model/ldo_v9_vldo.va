                       + (5.237327e-08)*max(vdrp-(2.435157e+00),0) + (9.214863e-08)*max(vdrp-(2.464141e+00),0) + (1.302882e-07)*max(vdrp-(2.493121e+00),0) + (1.663259e-07)*max(vdrp-(2.522095e+00),0)
