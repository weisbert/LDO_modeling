                       + (-3.609823e-06)*max(vdrp-(1.521432e+00),0) + (-3.357356e-06)*max(vdrp-(1.548913e+00),0) + (-3.120609e-06)*max(vdrp-(1.576522e+00),0) + (-2.898603e-06)*max(vdrp-(1.604250e+00),0)
                       + (-2.690276e-06)*max(vdrp-(1.632090e+00),0) + (-2.494780e-06)*max(vdrp-(1.660034e+00),0) + (-2.311193e-06)*max(vdrp-(1.688077e+00),0) + (-2.138739e-06)*max(vdrp-(1.716210e+00),0)
                       + (-1.976677e-06)*max(vdrp-(1.744428e+00),0) + (-1.824224e-06)*max(vdrp-(1.772726e+00),0) + (-1.680895e-06)*max(vdrp-(1.801096e+00),0) + (-1.545999e-06)*max(vdrp-(1.829534e+00),0)
                       + (-1.418982e-06)*max(vdrp-(1.858035e+00),0) + (-1.299279e-06)*max(vdrp-(1.886594e+00),0) + (-1.186548e-06)*max(vdrp-(1.915206e+00),0) + (-1.080208e-06)*max(vdrp-(1.943866e+00),0)
                       + (-9.798947e-07)*max(vdrp-(1.972571e+00),0) + (-8.853387e-07)*max(vdrp-(2.001316e+00),0) + (-7.957574e-07)*max(vdrp-(2.030098e+00),0) + (-7.113029e-07)*max(vdrp-(2.058913e+00),0)
                       + (-6.318729e-07)*max(vdrp-(2.087758e+00),0) + (-5.562270e-07)*max(vdrp-(2.116628e+00),0) + (-4.845311e-07)*max(vdrp-(2.145522e+00),0) + (-4.174352e-07)*max(vdrp-(2.174437e+00),0)
                       + (-3.532067e-07)*max(vdrp-(2.203368e+00),0) + (-2.927516e-07)*max(vdrp-(2.232315e+00),0) + (-2.353097e-07)*max(vdrp-(2.261274e+00),0) + (-1.808434e-07)*max(vdrp-(2.290242e+00),0)
