// ============================================================
// Behavioral LDO model for Cadence Spectre  (auto-gen: harness/fit_model.py)
// Equivalent to model/ldo_model.lib (validated in ngspice). NO laplace_nd.
//   Zout = (R_a + sL_a||R_pl) || (R_b+sL_b) || (ESR+1/sCout) ; R_pl damps L
//   PSRR = i_c*Zout, i_c = G0 + sum Gi/(1+s/wi) [real bank] + one signed COMPLEX 2nd-
//          order section (b0+b1 s)/(1+s/(Q w0)+(s/w0)^2) -> non-min-phase / notch PHASE
//          (V4/V3). LP filter resistors are noiseless conductances (no thermal noise).
//   Noise= DECOUPLED Norton @vout: white-R + 6 R||C-Lorentzian current sections,
//          transconducted into vout (gm sets amplitude) -> In*|Zout| = Sv. pnoise/hbnoise.
//   slew_en=1 : nonlinear DC-curve branch (current-limit + dropout), INLINE PWL
// Ports: vin vout gnd (explicit ground -- no global-ground references inside).
// Instance params: iload, slew_en, vdd (supply DC ref + dc_linereg Vout tracking),
//   voutdc (>0 pins Vout DC; 0 = characterized). Defaults = characterized behavior.
// Params interpolated as quadratics in ln(iload) through corners {20u,121u,250u}.
// ============================================================
`include "constants.vams"
`include "disciplines.vams"

module ldo_model(vin, vout, gnd);
  inout vin, vout, gnd;
  electrical vin, vout, gnd, vrg, nA, nC, nbb, np1, np2, np3, vrf, ncs1, ncs2, nw, nk1, nk2, nk3, nk4, nk5, nk6;

  parameter real iload   = 1.210000e-04 from (0:inf);
  parameter integer slew_en = 0 from [0:1];
  parameter real vdd    = 1.05;   // supply DC operating point [V]: PSRR DC reference
                                    // + dc_linereg Vout-DC tracking (clamped to the
                                    // characterized span [0.9,1.3]V)
  parameter real voutdc = 0 from [0:inf);   // >0: pin Vout DC at this iload [V]
                                            // (0 = characterized DC; small-signal unchanged)
  parameter real Cout = 9.996575e-10;   // auto-extracted physical output cap
  parameter real ESR  = 5.001136e-01;   // auto-extracted physical ESR
  parameter real VREG121 = 1.001324e+00;
  parameter real NRk = 1.000000e+06;   // fixed noise-section resistor (gm sets amplitude)
  parameter real Cn1 = 8.257796e-09;   // corner 19.27 Hz
  parameter real Cn2 = 5.535445e-10;   // corner 287.5 Hz
  parameter real Cn3 = 3.640863e-11;   // corner 4371 Hz
  parameter real Cn4 = 3.865440e-13;   // corner 4.117e+05 Hz
  parameter real Cn5 = 1.932921e-13;   // corner 8.234e+05 Hz
  parameter real Cn6 = 7.761084e-15;   // corner 2.051e+07 Hz

  real u, ic, R_a, L_a, R_pl, R_b, L_b, G0, G1, w1, G2, w2, G3, w3, gnw, gn1, gn2, gn3, gn4, gn5, gn6, vreg, Cps;
  real pcb0, pcb1, pcw0, pcq, pca1, pca2, Rpc, Lpc, Cpc, gqb1;
  real vddc, lrsh, vregeff, vdrp;

  analog begin
    @(initial_step) begin
      ic = min(max(iload, 2.000000e-05), 2.500000e-04);
      u  = ln(ic);
      R_a = min(max(exp((1.746864e-01)*u*u + (3.015499e+00)*u + (1.686286e+01)),4.765914e+01),1.089557e+02);
      L_a = min(max(exp((9.340099e-02)*u*u + (1.367675e+00)*u + (-6.412098e+00)),1.194163e-05),3.462885e-05);
      R_pl = min(max(exp((6.817964e-02)*u*u + (1.216997e-02)*u + (8.929824e-01)),2.391808e+02),6.297578e+03);
      R_b = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      L_b = min(max(exp((6.069877e-16)*u*u + (6.085391e-15)*u + (-2.763102e+01)),9.950249e-13),1.005000e-12);
      G0 = min(max((5.366832e-04)*u*u + (1.176336e-02)*u + (6.509545e-02),6.276616e-04),4.467644e-03);
      G1 = min(max((1.302487e-04)*u*u + (2.376015e-03)*u + (1.008185e-02),-7.545778e-04),-3.763224e-04);
      w1 = min(max(exp((4.319133e-02)*u*u + (8.585073e-01)*u + (1.919910e+01)),3.145744e+06),3.453066e+06);
      G2 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      w2 = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      G3 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      w3 = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      pcb0 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      pcb1 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      pcw0 = min(max(exp((4.717895e-16)*u*u + (1.054077e-14)*u + (1.219951e+01)),1.977032e+05),1.996852e+05);
      pcq = min(max(exp((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00)),9.950249e-01),1.005000e+00);
      gnw = min(max(exp((-2.824366e-02)*u*u + (-4.818732e-01)*u + (-1.035534e+01)),2.132628e-04),2.493657e-04);
      gn1 = min(max(exp((-2.143790e-01)*u*u + (-3.839081e+00)*u + (-1.776161e+01)),2.656892e-01),5.654884e-01);
      gn2 = min(max(exp((-2.139306e-01)*u*u + (-3.829244e+00)*u + (-1.913244e+01)),6.391532e-02),1.362669e-01);
      gn3 = min(max(exp((-2.159520e-01)*u*u + (-3.873445e+00)*u + (-2.067783e+01)),1.735329e-02),3.672514e-02);
      gn4 = min(max(exp((-2.266996e-01)*u*u + (-4.078931e+00)*u + (-2.236891e+01)),8.396458e-03),1.801898e-02);
      gn5 = min(max(exp((3.474006e+00)*u*u + (6.970738e+01)*u + (3.335723e+02)),8.676416e-07),3.705705e-03);
      gn6 = min(max(exp((2.557289e-02)*u*u + (6.928580e-01)*u + (-1.304737e+01)),2.376229e-08),4.018447e-08);
      vreg = min(max((5.528135e-04)*u*u + (9.609886e-03)*u + (1.043029e+00),1.001312e+00),1.003781e+00);
      Cps = 1e-12;
      // complex PSRR section: a1=1/(Q.w0), a2=1/w0^2 ; series R-L-C (Cpc fixed)
      Cpc = 1e-12;
      pca1 = 1.0/(pcq*pcw0); pca2 = 1.0/(pcw0*pcw0);
      Rpc = pca1/Cpc; Lpc = pca2/Cpc; gqb1 = pcb1/pca1;
      // R3-L1: vdd line-reg DC shift (characterized dc_linereg poly) / voutdc override
      vddc = min(max(vdd, 9.000000e-01), 1.300000e+00);
      lrsh = (-5.897381e+00)*vddc*vddc*vddc*vddc + (3.277786e+01)*vddc*vddc*vddc + (-6.668670e+01)*vddc*vddc + (5.917135e+01)*vddc + (-1.839035e+01) - (9.936500e-01);
      vregeff = (voutdc > 0) ? voutdc + R_a*ic : vreg + lrsh;
    end

    // ---- references / DC operating point ----
    V(vrf, gnd) <+ vdd;              // supply DC reference (settable; no DC coupling)
    V(vrg, gnd) <+ vregeff;          // regulated output reference (incl. R3-L1 shift)

    // ---- Zout branch C: series Cout + ESR (vout -> vrg) ----
    I(vout, nC) <+ Cout*ddt(V(vout, nC));
    V(nC, vrg)  <+ ESR*I(nC, vrg);

    // ---- Zout branch B: optional 2nd R-L (R_b->inf disables it) ----
    I(vout, nbb) <+ idt(V(vout, nbb))/L_b;
    V(nbb, vrg)  <+ R_b*I(nbb, vrg);

    // ---- Zout branch A: (L_a || R_pl) + (R_a | nonlinear dropout) ----
    // L_a||R_pl as summed current contributions (idt form admits the parallel R)
    I(vout, nA) <+ idt(V(vout, nA))/L_a + V(vout, nA)/R_pl;
    if (slew_en == 0)
      V(nA, vrg) <+ R_a*I(nA, vrg);
    else begin
      // nonlinear DC-curve branch (current-limit + dropout): INLINE closed-form PWL of
      // the characterized (Vdrop, Iload) table -- i = i1 + g1*(v-v1) + sum dg_k*max(v-v_k,0)
      // == 1-D linear table interpolation, linear end extrapolation. Self-contained
      // (no external table file -> no run-dir path issues; OpenVAF-compilable, R8 closed).
      vdrp = V(vrg, nA) - (vregeff - VREG121);
      I(vrg, nA) <+ (1.000000e-06) + (3.253531e-03)*(vdrp-(-4.832704e-03)) + (5.511543e-03)*max(vdrp-(-1.144404e-03),0) + (3.465596e-03)*max(vdrp-(2.246656e-04),0) + (2.502910e-03)*max(vdrp-(1.205806e-03),0)
                       + (1.839792e-03)*max(vdrp-(2.020272e-03),0) + (1.359960e-03)*max(vdrp-(2.744325e-03),0) + (1.004447e-03)*max(vdrp-(3.413470e-03),0) + (7.374477e-04)*max(vdrp-(4.047124e-03),0)
                       + (5.355030e-04)*max(vdrp-(4.657028e-03),0) + (3.824209e-04)*max(vdrp-(5.250772e-03),0) + (2.664737e-04)*max(vdrp-(5.833490e-03),0) + (1.786856e-04)*max(vdrp-(6.408764e-03),0)
                       + (1.123560e-04)*max(vdrp-(6.979152e-03),0) + (6.221510e-05)*max(vdrp-(7.546510e-03),0) + (2.395129e-05)*max(vdrp-(8.112204e-03),0) + (-5.560915e-06)*max(vdrp-(8.677260e-03),0)
                       + (-2.910963e-05)*max(vdrp-(9.242464e-03),0) + (-4.873682e-05)*max(vdrp-(9.808444e-03),0) + (-6.612966e-05)*max(vdrp-(1.037573e-02),0) + (-8.279067e-05)*max(vdrp-(1.094479e-02),0)
                       + (-9.974754e-05)*max(vdrp-(1.151610e-02),0) + (-1.181944e-04)*max(vdrp-(1.209013e-02),0) + (-1.390223e-04)*max(vdrp-(1.266742e-02),0) + (-1.632937e-04)*max(vdrp-(1.324861e-02),0)
                       + (-1.920741e-04)*max(vdrp-(1.383442e-02),0) + (-2.266260e-04)*max(vdrp-(1.442578e-02),0) + (-2.683695e-04)*max(vdrp-(1.502382e-02),0) + (-3.190300e-04)*max(vdrp-(1.562997e-02),0)
                       + (-3.805113e-04)*max(vdrp-(1.624605e-02),0) + (-4.547169e-04)*max(vdrp-(1.687440e-02),0) + (-5.432903e-04)*max(vdrp-(1.751807e-02),0) + (-6.459725e-04)*max(vdrp-(1.818107e-02),0)
                       + (-7.597003e-04)*max(vdrp-(1.886860e-02),0) + (-8.754477e-04)*max(vdrp-(1.958743e-02),0) + (-9.769243e-04)*max(vdrp-(2.034603e-02),0) + (-1.041740e-03)*max(vdrp-(2.115457e-02),0)
                       + (-1.048673e-03)*max(vdrp-(2.202415e-02),0) + (-9.895214e-04)*max(vdrp-(2.296524e-02),0) + (-8.759240e-04)*max(vdrp-(2.398550e-02),0) + (-7.340689e-04)*max(vdrp-(2.508786e-02),0)
                       + (-5.910013e-04)*max(vdrp-(2.626994e-02),0) + (-3.922846e-04)*max(vdrp-(2.752508e-02),0) + (-4.302749e-04)*max(vdrp-(2.839764e-02),0) + (-4.356242e-04)*max(vdrp-(3.068647e-02),0)
                       + (-2.940956e-04)*max(vdrp-(3.309539e-02),0) + (-2.059316e-04)*max(vdrp-(3.559278e-02),0) + (-8.241370e-05)*max(vdrp-(3.815608e-02),0) + (-2.025826e-04)*max(vdrp-(4.074674e-02),0)
                       + (-7.332269e-05)*max(vdrp-(4.340722e-02),0) + (-7.066408e-05)*max(vdrp-(4.609390e-02),0) + (-5.771297e-05)*max(vdrp-(4.880633e-02),0) + (-4.931334e-05)*max(vdrp-(5.154016e-02),0)
                       + (-4.290999e-05)*max(vdrp-(5.429254e-02),0) + (-3.803051e-05)*max(vdrp-(5.706127e-02),0) + (-3.423804e-05)*max(vdrp-(5.984465e-02),0) + (-3.125284e-05)*max(vdrp-(6.264137e-02),0)
                       + (-2.887710e-05)*max(vdrp-(6.545035e-02),0) + (-2.695751e-05)*max(vdrp-(6.827078e-02),0) + (-2.539607e-05)*max(vdrp-(7.110197e-02),0) + (-2.411209e-05)*max(vdrp-(7.394337e-02),0)
                       + (-2.305058e-05)*max(vdrp-(7.679454e-02),0) + (-2.215892e-05)*max(vdrp-(7.965511e-02),0) + (-2.141069e-05)*max(vdrp-(8.252478e-02),0) + (-2.077812e-05)*max(vdrp-(8.540329e-02),0)
                       + (-2.023919e-05)*max(vdrp-(8.829043e-02),0) + (-1.977739e-05)*max(vdrp-(9.118603e-02),0) + (-1.937438e-05)*max(vdrp-(9.408995e-02),0) + (-1.903350e-05)*max(vdrp-(9.700206e-02),0)
                       + (-1.873004e-05)*max(vdrp-(9.992227e-02),0) + (-1.847012e-05)*max(vdrp-(1.028505e-01),0) + (-1.823897e-05)*max(vdrp-(1.057866e-01),0) + (-1.803368e-05)*max(vdrp-(1.087307e-01),0)
                       + (-1.785828e-05)*max(vdrp-(1.116825e-01),0) + (-1.769625e-05)*max(vdrp-(1.146422e-01),0) + (-1.755862e-05)*max(vdrp-(1.176096e-01),0) + (-1.742691e-05)*max(vdrp-(1.205848e-01),0)
                       + (-1.731890e-05)*max(vdrp-(1.235678e-01),0) + (-1.721631e-05)*max(vdrp-(1.265584e-01),0) + (-1.712568e-05)*max(vdrp-(1.295568e-01),0) + (-1.704237e-05)*max(vdrp-(1.325629e-01),0)
                       + (-1.697281e-05)*max(vdrp-(1.355767e-01),0) + (-1.690583e-05)*max(vdrp-(1.385982e-01),0) + (-1.684788e-05)*max(vdrp-(1.416275e-01),0) + (-1.679231e-05)*max(vdrp-(1.446645e-01),0)
                       + (-1.674767e-05)*max(vdrp-(1.477093e-01),0) + (-1.670306e-05)*max(vdrp-(1.507619e-01),0) + (-1.666698e-05)*max(vdrp-(1.538222e-01),0) + (-1.663502e-05)*max(vdrp-(1.568904e-01),0)
