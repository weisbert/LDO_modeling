                       + (6.817331e-07)*max(vdrp-(3.143439e+00),0) + (6.926929e-07)*max(vdrp-(3.171921e+00),0) + (7.029712e-07)*max(vdrp-(3.200376e+00),0) + (7.130591e-07)*max(vdrp-(3.228802e+00),0)
