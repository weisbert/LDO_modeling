                       + (-8.388743e-06)*max(vdrp-(1.106103e+00),0) + (-7.827198e-06)*max(vdrp-(1.131316e+00),0) + (-7.303149e-06)*max(vdrp-(1.156780e+00),0) + (-6.813472e-06)*max(vdrp-(1.182483e+00),0)
                       + (-6.355545e-06)*max(vdrp-(1.208413e+00),0) + (-5.927424e-06)*max(vdrp-(1.234559e+00),0) + (-5.527031e-06)*max(vdrp-(1.260909e+00),0) + (-5.152335e-06)*max(vdrp-(1.287452e+00),0)
                       + (-4.801832e-06)*max(vdrp-(1.314178e+00),0) + (-4.473710e-06)*max(vdrp-(1.341077e+00),0) + (-4.166478e-06)*max(vdrp-(1.368138e+00),0) + (-3.878809e-06)*max(vdrp-(1.395353e+00),0)
                       + (-3.609254e-06)*max(vdrp-(1.422712e+00),0) + (-3.356710e-06)*max(vdrp-(1.450207e+00),0) + (-3.119854e-06)*max(vdrp-(1.477829e+00),0) + (-2.897813e-06)*max(vdrp-(1.505571e+00),0)
                       + (-2.689468e-06)*max(vdrp-(1.533425e+00),0) + (-2.493897e-06)*max(vdrp-(1.561384e+00),0) + (-2.310255e-06)*max(vdrp-(1.589440e+00),0) + (-2.137763e-06)*max(vdrp-(1.617588e+00),0)
                       + (-1.975683e-06)*max(vdrp-(1.645820e+00),0) + (-1.823229e-06)*max(vdrp-(1.674132e+00),0) + (-1.679843e-06)*max(vdrp-(1.702517e+00),0) + (-1.544958e-06)*max(vdrp-(1.730969e+00),0)
                       + (-1.417896e-06)*max(vdrp-(1.759485e+00),0) + (-1.298240e-06)*max(vdrp-(1.788058e+00),0) + (-1.185429e-06)*max(vdrp-(1.816684e+00),0) + (-1.079148e-06)*max(vdrp-(1.845359e+00),0)
                       + (-9.787919e-07)*max(vdrp-(1.874078e+00),0) + (-8.842361e-07)*max(vdrp-(1.902838e+00),0) + (-7.945297e-07)*max(vdrp-(1.931634e+00),0) + (-7.105944e-07)*max(vdrp-(1.960463e+00),0)
                       + (-6.305250e-07)*max(vdrp-(1.989322e+00),0) + (-5.549571e-07)*max(vdrp-(2.018207e+00),0) + (-4.838127e-07)*max(vdrp-(2.047115e+00),0) + (-4.160680e-07)*max(vdrp-(2.076044e+00),0)
                       + (-3.523819e-07)*max(vdrp-(2.104990e+00),0) + (-2.915108e-07)*max(vdrp-(2.133951e+00),0) + (-2.343649e-07)*max(vdrp-(2.162924e+00),0) + (-1.799527e-07)*max(vdrp-(2.191906e+00),0)
                       + (-1.280044e-07)*max(vdrp-(2.220897e+00),0) + (-7.920572e-08)*max(vdrp-(2.249892e+00),0) + (-3.281866e-08)*max(vdrp-(2.278891e+00),0) + (1.141483e-08)*max(vdrp-(2.307892e+00),0)
                       + (5.351207e-08)*max(vdrp-(2.336892e+00),0) + (9.301183e-08)*max(vdrp-(2.365890e+00),0) + (1.311155e-07)*max(vdrp-(2.394883e+00),0) + (1.673577e-07)*max(vdrp-(2.423872e+00),0)
