// ============================================================
// Behavioral LDO model for Cadence Spectre  (auto-gen: harness/fit_model.py)
// Equivalent to model/ldo_model.lib (validated in ngspice). NO laplace_nd.
//   Zout = (R_a + sL_a||R_pl) || (R_b+sL_b) || (ESR+1/sCout) ; R_pl damps L
//   PSRR = i_c*Zout, i_c = G0 + sum Gi/(1+s/wi) [real bank] + one signed COMPLEX 2nd-
//          order section (b0+b1 s)/(1+s/(Q w0)+(s/w0)^2) -> non-min-phase / notch PHASE
//          (V4/V3). LP filter resistors are noiseless conductances (no thermal noise).
//   Noise= DECOUPLED Norton @vout: white-R + 6 R||C-Lorentzian current sections,
//          transconducted into vout (gm sets amplitude) -> In*|Zout| = Sv. pnoise/hbnoise.
//   slew_en=1 : nonlinear DC-curve branch (current-limit + dropout), INLINE PWL
// Ports: vin vout gnd (explicit ground -- no global-ground references inside).
// Instance params: iload, slew_en, vdd (supply DC ref + dc_linereg Vout tracking),
//   voutdc (>0 pins Vout DC; 0 = characterized). Defaults = characterized behavior.
// Params interpolated as quadratics in ln(iload) through corners {20u,121u,250u}.
// ============================================================
`include "constants.vams"
`include "disciplines.vams"

module ldo_model(vin, vout, gnd);
  inout vin, vout, gnd;
  electrical vin, vout, gnd, vrg, nA, nC, nbb, np1, np2, np3, vrf, ncs1, ncs2, nw, nk1, nk2, nk3, nk4, nk5, nk6;

  parameter real iload   = 1.210000e-04 from (0:inf);
  parameter integer slew_en = 0 from [0:1];
  parameter real vdd    = 1.05;   // supply DC operating point [V]: PSRR DC reference
                                    // + dc_linereg Vout-DC tracking (clamped to the
                                    // characterized span [0.9,1.3]V)
  parameter real voutdc = 0 from [0:inf);   // >0: pin Vout DC at this iload [V]
                                            // (0 = characterized DC; small-signal unchanged)
  parameter real Cout = 9.964926e-10;   // auto-extracted physical output cap
  parameter real ESR  = 5.000090e-01;   // auto-extracted physical ESR
  parameter real VREG121 = 9.023707e-01;
  parameter real NRk = 1.000000e+06;   // fixed noise-section resistor (gm sets amplitude)
  parameter real Cn1 = 3.404185e-08;   // corner 4.675 Hz
  parameter real Cn2 = 9.927200e-09;   // corner 16.03 Hz
  parameter real Cn3 = 8.543917e-10;   // corner 186.3 Hz
  parameter real Cn4 = 7.684787e-11;   // corner 2071 Hz
  parameter real Cn5 = 8.054857e-12;   // corner 1.976e+04 Hz
  parameter real Cn6 = 2.351824e-13;   // corner 6.767e+05 Hz

  real u, ic, R_a, L_a, R_pl, R_b, L_b, G0, G1, w1, G2, w2, G3, w3, gnw, gn1, gn2, gn3, gn4, gn5, gn6, vreg, Cps;
  real pcb0, pcb1, pcw0, pcq, pca1, pca2, Rpc, Lpc, Cpc, gqb1;
  real vddc, lrsh, vregeff, vdrp;

  analog begin
    @(initial_step) begin
      ic = min(max(iload, 2.000000e-05), 2.500000e-04);
      u  = ln(ic);
      R_a = min(max(exp((1.769491e-01)*u*u + (2.749437e+00)*u + (1.347382e+01)),1.707155e+01),8.524342e+01);
      L_a = min(max(exp((1.417878e-01)*u*u + (2.106118e+00)*u + (-4.851080e+00)),3.472776e-06),1.612615e-05);
      R_pl = min(max(exp((9.865508e-13)*u*u + (1.892035e-11)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      R_b = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      L_b = min(max(exp((6.069877e-16)*u*u + (6.085391e-15)*u + (-2.763102e+01)),9.950249e-13),1.005000e-12);
      G0 = min(max((2.025301e-04)*u*u + (4.721027e-03)*u + (2.782683e-02),4.453500e-04),2.613434e-03);
      G1 = min(max((6.360317e-05)*u*u + (6.972497e-04)*u + (-3.287653e-04),-1.742994e-03),-4.204337e-04);
      w1 = min(max(exp((3.989357e-02)*u*u + (7.492133e-01)*u + (1.902817e+01)),5.449527e+06),5.939147e+06);
      G2 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      w2 = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      G3 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      w3 = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      pcb0 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      pcb1 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      pcw0 = min(max(exp((4.717895e-16)*u*u + (1.054077e-14)*u + (1.219951e+01)),1.977032e+05),1.996852e+05);
      pcq = min(max(exp((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00)),9.950249e-01),1.005000e+00);
      gnw = min(max(exp((-6.854036e+00)*u*u + (-1.368002e+02)*u + (-6.861171e+02)),1.034626e-10),2.365576e-04);
      gn1 = min(max(exp((-9.991710e+00)*u*u + (-1.928496e+02)*u + (-9.469529e+02)),7.730395e-16),1.412740e-09);
      gn2 = min(max(exp((-1.796665e-01)*u*u + (-2.807131e+00)*u + (-1.065709e+01)),2.664215e-01),1.311133e+00);
      gn3 = min(max(exp((-1.841195e-01)*u*u + (-2.883311e+00)*u + (-1.229613e+01)),7.003491e-02),3.525260e-01);
      gn4 = min(max(exp((-1.659086e-01)*u*u + (-2.572329e+00)*u + (-1.218008e+01)),2.292411e-02),1.050694e-01);
      gn5 = min(max(exp((-4.314887e+00)*u*u + (-7.437066e+01)*u + (-3.234156e+02)),4.256091e-11),3.326539e-02);
      gn6 = min(max(exp((-1.682321e-01)*u*u + (-2.616410e+00)*u + (-1.308339e+01)),1.140257e-02),5.230541e-02);
      vreg = min(max((1.400092e-04)*u*u + (1.155014e-03)*u + (9.013981e-01),9.014305e-01),9.053108e-01);
      Cps = 1e-12;
      // complex PSRR section: a1=1/(Q.w0), a2=1/w0^2 ; series R-L-C (Cpc fixed)
      Cpc = 1e-12;
      pca1 = 1.0/(pcq*pcw0); pca2 = 1.0/(pcw0*pcw0);
      Rpc = pca1/Cpc; Lpc = pca2/Cpc; gqb1 = pcb1/pca1;
      // R3-L1: vdd line-reg DC shift (characterized dc_linereg poly) / voutdc override
      vddc = min(max(vdd, 9.000000e-01), 1.300000e+00);
      lrsh = (-1.004245e+01)*vddc*vddc*vddc*vddc + (4.561989e+01)*vddc*vddc*vddc + (-7.745911e+01)*vddc*vddc + (5.826194e+01)*vddc + (-1.548001e+01) - (9.004299e-01);
      vregeff = (voutdc > 0) ? voutdc + R_a*ic : vreg + lrsh;
    end

    // ---- references / DC operating point ----
    V(vrf, gnd) <+ vdd;              // supply DC reference (settable; no DC coupling)
    V(vrg, gnd) <+ vregeff;          // regulated output reference (incl. R3-L1 shift)

    // ---- Zout branch C: series Cout + ESR (vout -> vrg) ----
    I(vout, nC) <+ Cout*ddt(V(vout, nC));
    V(nC, vrg)  <+ ESR*I(nC, vrg);

    // ---- Zout branch B: optional 2nd R-L (R_b->inf disables it) ----
    I(vout, nbb) <+ idt(V(vout, nbb))/L_b;
    V(nbb, vrg)  <+ R_b*I(nbb, vrg);

    // ---- Zout branch A: (L_a || R_pl) + (R_a | nonlinear dropout) ----
    // L_a||R_pl as summed current contributions (idt form admits the parallel R)
    I(vout, nA) <+ idt(V(vout, nA))/L_a + V(vout, nA)/R_pl;
    if (slew_en == 0)
      V(nA, vrg) <+ R_a*I(nA, vrg);
    else begin
      // nonlinear DC-curve branch (current-limit + dropout): INLINE closed-form PWL of
      // the characterized (Vdrop, Iload) table -- i = i1 + g1*(v-v1) + sum dg_k*max(v-v_k,0)
      // == 1-D linear table interpolation, linear end extrapolation. Self-contained
      // (no external table file -> no run-dir path issues; OpenVAF-compilable, R8 closed).
      vdrp = V(vrg, nA) - (vregeff - VREG121);
      I(vrg, nA) <+ (1.000000e-06) + (3.234370e-03)*(vdrp-(-5.653363e-03)) + (7.559307e-03)*max(vdrp-(-1.943212e-03),0) + (5.754486e-03)*max(vdrp-(-8.314499e-04),0) + (4.985307e-03)*max(vdrp-(-1.062939e-04),0)
                       + (4.377741e-03)*max(vdrp-(4.509781e-04),0) + (3.868715e-03)*max(vdrp-(9.140981e-04),0) + (3.429885e-03)*max(vdrp-(1.317054e-03),0) + (3.044184e-03)*max(vdrp-(1.678393e-03),0)
                       + (2.700973e-03)*max(vdrp-(2.009391e-03),0) + (2.392120e-03)*max(vdrp-(2.317439e-03),0) + (2.113379e-03)*max(vdrp-(2.607665e-03),0) + (1.860005e-03)*max(vdrp-(2.883778e-03),0)
                       + (1.631007e-03)*max(vdrp-(3.148559e-03),0) + (1.422353e-03)*max(vdrp-(3.404142e-03),0) + (1.234263e-03)*max(vdrp-(3.652210e-03),0) + (1.063514e-03)*max(vdrp-(3.894106e-03),0)
                       + (9.106767e-04)*max(vdrp-(4.130925e-03),0) + (7.723638e-04)*max(vdrp-(4.363563e-03),0) + (6.491173e-04)*max(vdrp-(4.592769e-03),0) + (5.384995e-04)*max(vdrp-(4.819168e-03),0)
                       + (4.400536e-04)*max(vdrp-(5.043290e-03),0) + (3.519709e-04)*max(vdrp-(5.265585e-03),0) + (2.739623e-04)*max(vdrp-(5.486440e-03),0) + (2.042871e-04)*max(vdrp-(5.706187e-03),0)
                       + (1.428305e-04)*max(vdrp-(5.925115e-03),0) + (8.772250e-05)*max(vdrp-(6.143474e-03),0) + (3.890918e-05)*max(vdrp-(6.361485e-03),0) + (-4.297870e-06)*max(vdrp-(6.579342e-03),0)
                       + (-4.294184e-05)*max(vdrp-(6.797216e-03),0) + (-7.737850e-05)*max(vdrp-(7.015260e-03),0) + (-1.082659e-04)*max(vdrp-(7.233611e-03),0) + (-1.355448e-04)*max(vdrp-(7.452393e-03),0)
                       + (-1.604329e-04)*max(vdrp-(7.671717e-03),0) + (-1.826611e-04)*max(vdrp-(7.891686e-03),0) + (-2.027229e-04)*max(vdrp-(8.112394e-03),0) + (-2.213533e-04)*max(vdrp-(8.333928e-03),0)
                       + (-2.383078e-04)*max(vdrp-(8.556371e-03),0) + (-2.535996e-04)*max(vdrp-(8.779801e-03),0) + (-2.684298e-04)*max(vdrp-(9.004291e-03),0) + (-2.823122e-04)*max(vdrp-(9.229914e-03),0)
                       + (-2.952498e-04)*max(vdrp-(9.456741e-03),0) + (3.705748e-04)*max(vdrp-(9.684841e-03),0) + (-9.780815e-04)*max(vdrp-(9.835844e-03),0) + (-5.606692e-04)*max(vdrp-(1.022045e-02),0)
                       + (-5.942505e-04)*max(vdrp-(1.060925e-02),0) + (-6.290155e-04)*max(vdrp-(1.100260e-02),0) + (-6.662415e-04)*max(vdrp-(1.140087e-02),0) + (-7.067175e-04)*max(vdrp-(1.180449e-02),0)
                       + (-7.516899e-04)*max(vdrp-(1.221396e-02),0) + (-8.022585e-04)*max(vdrp-(1.262983e-02),0) + (-8.599428e-04)*max(vdrp-(1.305275e-02),0) + (-9.262337e-04)*max(vdrp-(1.348350e-02),0)
                       + (-1.002969e-03)*max(vdrp-(1.392302e-02),0) + (-1.092392e-03)*max(vdrp-(1.437245e-02),0) + (-1.197160e-03)*max(vdrp-(1.483319e-02),0) + (-1.319691e-03)*max(vdrp-(1.530699e-02),0)
                       + (-1.462856e-03)*max(vdrp-(1.579609e-02),0) + (-1.629302e-03)*max(vdrp-(1.630333e-02),0) + (-1.819391e-03)*max(vdrp-(1.683244e-02),0) + (-2.031393e-03)*max(vdrp-(1.738830e-02),0)
                       + (-2.257173e-03)*max(vdrp-(1.797742e-02),0) + (-2.479476e-03)*max(vdrp-(1.860850e-02),0) + (-2.669306e-03)*max(vdrp-(1.929315e-02),0) + (-2.786347e-03)*max(vdrp-(2.004665e-02),0)
                       + (-2.787240e-03)*max(vdrp-(2.088852e-02),0) + (-2.643106e-03)*max(vdrp-(2.184230e-02),0) + (-2.359619e-03)*max(vdrp-(2.293363e-02),0) + (-1.982746e-03)*max(vdrp-(2.418625e-02),0)
                       + (-1.581436e-03)*max(vdrp-(2.561647e-02),0) + (-1.215938e-03)*max(vdrp-(2.722907e-02),0) + (-9.179650e-04)*max(vdrp-(2.901695e-02),0) + (-6.915311e-04)*max(vdrp-(3.096466e-02),0)
                       + (-5.256091e-04)*max(vdrp-(3.305300e-02),0) + (-4.055457e-04)*max(vdrp-(3.526262e-02),0) + (-3.184335e-04)*max(vdrp-(3.757589e-02),0) + (-2.545773e-04)*max(vdrp-(3.997761e-02),0)
                       + (-2.071200e-04)*max(vdrp-(4.245507e-02),0) + (-1.712873e-04)*max(vdrp-(4.499777e-02),0) + (-1.438213e-04)*max(vdrp-(4.759708e-02),0) + (-1.224447e-04)*max(vdrp-(5.024589e-02),0)
                       + (-1.055893e-04)*max(vdrp-(5.293837e-02),0) + (-9.211062e-05)*max(vdrp-(5.566967e-02),0) + (-8.121004e-05)*max(vdrp-(5.843577e-02),0) + (-7.229146e-05)*max(vdrp-(6.123328e-02),0)
                       + (-6.492437e-05)*max(vdrp-(6.405938e-02),0) + (-5.877985e-05)*max(vdrp-(6.691164e-02),0) + (-5.361593e-05)*max(vdrp-(6.978801e-02),0) + (-4.923312e-05)*max(vdrp-(7.268674e-02),0)
                       + (-4.548990e-05)*max(vdrp-(7.560630e-02),0) + (-4.227941e-05)*max(vdrp-(7.854538e-02),0) + (-3.949353e-05)*max(vdrp-(8.150283e-02),0) + (-3.707975e-05)*max(vdrp-(8.447765e-02),0)
                       + (-3.495927e-05)*max(vdrp-(8.746897e-02),0) + (-3.310682e-05)*max(vdrp-(9.047602e-02),0) + (-3.146682e-05)*max(vdrp-(9.349811e-02),0) + (-3.001285e-05)*max(vdrp-(9.653463e-02),0)
                       + (-2.872445e-05)*max(vdrp-(9.958506e-02),0) + (-2.757613e-05)*max(vdrp-(1.026489e-01),0) + (-2.654378e-05)*max(vdrp-(1.057258e-01),0) + (-2.562531e-05)*max(vdrp-(1.088152e-01),0)
                       + (-2.479618e-05)*max(vdrp-(1.119170e-01),0) + (-2.405139e-05)*max(vdrp-(1.150307e-01),0) + (-2.337808e-05)*max(vdrp-(1.181561e-01),0) + (-2.277404e-05)*max(vdrp-(1.212930e-01),0)
                       + (-2.222920e-05)*max(vdrp-(1.244411e-01),0) + (-2.173587e-05)*max(vdrp-(1.276003e-01),0) + (-2.129457e-05)*max(vdrp-(1.307703e-01),0) + (-2.089800e-05)*max(vdrp-(1.339511e-01),0)
                       + (-2.053717e-05)*max(vdrp-(1.371425e-01),0) + (-2.022275e-05)*max(vdrp-(1.403444e-01),0) + (-1.993817e-05)*max(vdrp-(1.435567e-01),0) + (-1.968841e-05)*max(vdrp-(1.467793e-01),0)
                       + (-1.947261e-05)*max(vdrp-(1.500122e-01),0) + (-1.928427e-05)*max(vdrp-(1.532553e-01),0) + (-1.912836e-05)*max(vdrp-(1.565085e-01),0) + (-1.899850e-05)*max(vdrp-(1.597720e-01),0)
