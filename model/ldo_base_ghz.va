                       + (-3.609219e-06)*max(vdrp-(1.421469e+00),0) + (-3.356624e-06)*max(vdrp-(1.448964e+00),0) + (-3.119874e-06)*max(vdrp-(1.476587e+00),0) + (-2.897755e-06)*max(vdrp-(1.504329e+00),0)
                       + (-2.689412e-06)*max(vdrp-(1.532183e+00),0) + (-2.493867e-06)*max(vdrp-(1.560141e+00),0) + (-2.310225e-06)*max(vdrp-(1.588198e+00),0) + (-2.137759e-06)*max(vdrp-(1.616345e+00),0)
                       + (-1.975630e-06)*max(vdrp-(1.644578e+00),0) + (-1.823202e-06)*max(vdrp-(1.672890e+00),0) + (-1.679841e-06)*max(vdrp-(1.701274e+00),0) + (-1.544931e-06)*max(vdrp-(1.729727e+00),0)
                       + (-1.417870e-06)*max(vdrp-(1.758242e+00),0) + (-1.298190e-06)*max(vdrp-(1.786816e+00),0) + (-1.185452e-06)*max(vdrp-(1.815442e+00),0) + (-1.079098e-06)*max(vdrp-(1.844117e+00),0)
                       + (-9.786941e-07)*max(vdrp-(1.872836e+00),0) + (-8.844283e-07)*max(vdrp-(1.901596e+00),0) + (-7.945286e-07)*max(vdrp-(1.930392e+00),0) + (-7.103532e-07)*max(vdrp-(1.959221e+00),0)
                       + (-6.305246e-07)*max(vdrp-(1.988080e+00),0) + (-5.549568e-07)*max(vdrp-(2.016965e+00),0) + (-4.838124e-07)*max(vdrp-(2.045873e+00),0) + (-4.163064e-07)*max(vdrp-(2.074802e+00),0)
                       + (-3.521430e-07)*max(vdrp-(2.103748e+00),0) + (-2.915106e-07)*max(vdrp-(2.132709e+00),0) + (-2.343647e-07)*max(vdrp-(2.161682e+00),0) + (-1.797146e-07)*max(vdrp-(2.190664e+00),0)
                       + (-1.282423e-07)*max(vdrp-(2.219655e+00),0) + (-7.944350e-08)*max(vdrp-(2.248650e+00),0) + (-3.234301e-08)*max(vdrp-(2.277650e+00),0) + (1.117702e-08)*max(vdrp-(2.306650e+00),0)
                       + (5.351203e-08)*max(vdrp-(2.335650e+00),0) + (9.301177e-08)*max(vdrp-(2.364648e+00),0) + (1.313535e-07)*max(vdrp-(2.393641e+00),0) + (1.671196e-07)*max(vdrp-(2.422630e+00),0)
