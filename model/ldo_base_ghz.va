// ============================================================
// Behavioral LDO model for Cadence Spectre  (auto-gen: harness/fit_model.py)
// Equivalent to model/ldo_model.lib (validated in ngspice). NO laplace_nd.
//   Zout = (R_a + sL_a||R_pl) || (R_b+sL_b) || (ESR+1/sCout) ; R_pl damps L
//   PSRR = i_c*Zout, i_c = G0 + sum Gi/(1+s/wi) [real bank] + one signed COMPLEX 2nd-
//          order section (b0+b1 s)/(1+s/(Q w0)+(s/w0)^2) -> non-min-phase / notch PHASE
//          (V4/V3). LP filter resistors are noiseless conductances (no thermal noise).
//   Noise= DECOUPLED Norton @vout: white-R + 6 R||C-Lorentzian current sections,
//          transconducted into vout (gm sets amplitude) -> In*|Zout| = Sv. pnoise/hbnoise.
//   slew_en=1 : nonlinear DC-curve branch (current-limit + dropout), INLINE PWL
// Ports: vin vout gnd (explicit ground -- no global-ground references inside).
// Instance params: iload, slew_en, vdd (supply DC ref + dc_linereg Vout tracking),
//   voutdc (>0 pins Vout DC; 0 = characterized). Defaults = characterized behavior.
// Params interpolated as quadratics in ln(iload) through corners {20u,121u,250u}.
// ============================================================
`include "constants.vams"
`include "disciplines.vams"

module ldo_model(vin, vout, gnd);
  inout vin, vout, gnd;
  electrical vin, vout, gnd, vrg, nA, nC, nbb, np1, np2, np3, vrf, ncs1, ncs2, nw, nk1, nk2, nk3, nk4, nk5, nk6;

  parameter real iload   = 1.210000e-04 from (0:inf);
  parameter integer slew_en = 0 from [0:1];
  parameter real vdd    = 1.05;   // supply DC operating point [V]: PSRR DC reference
                                    // + dc_linereg Vout-DC tracking (clamped to the
                                    // characterized span [0.9,1.3]V)
  parameter real voutdc = 0 from [0:inf);   // >0: pin Vout DC at this iload [V]
                                            // (0 = characterized DC; small-signal unchanged)
  parameter real Cout = 9.970359e-10;   // auto-extracted physical output cap
  parameter real ESR  = 4.999277e-01;   // auto-extracted physical ESR
  parameter real VREG121 = 9.011240e-01;
  parameter real NRk = 1.000000e+06;   // fixed noise-section resistor (gm sets amplitude)
  parameter real Cn1 = 8.589054e-09;   // corner 18.53 Hz
  parameter real Cn2 = 6.072751e-10;   // corner 262.1 Hz
  parameter real Cn3 = 4.191312e-11;   // corner 3797 Hz
  parameter real Cn4 = 4.053816e-13;   // corner 3.926e+05 Hz
  parameter real Cn5 = 2.026957e-13;   // corner 7.852e+05 Hz
  parameter real Cn6 = 2.128851e-15;   // corner 7.476e+07 Hz

  real u, ic, R_a, L_a, R_pl, R_b, L_b, G0, G1, w1, G2, w2, G3, w3, gnw, gn1, gn2, gn3, gn4, gn5, gn6, vreg, Cps;
  real pcb0, pcb1, pcw0, pcq, pca1, pca2, Rpc, Lpc, Cpc, gqb1;
  real vddc, lrsh, vregeff, vdrp;

  analog begin
    @(initial_step) begin
      ic = min(max(iload, 2.000000e-05), 2.500000e-04);
      u  = ln(ic);
      R_a = min(max(exp((1.836695e-01)*u*u + (2.900074e+00)*u + (1.429934e+01)),1.774067e+01),8.375780e+01);
      L_a = min(max(exp((1.396678e-01)*u*u + (2.061221e+00)*u + (-4.541528e+00)),5.936079e-06),2.787104e-05);
      R_pl = min(max(exp((6.879801e-14)*u*u + (1.671526e-12)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      R_b = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      L_b = min(max(exp((6.069877e-16)*u*u + (6.085391e-15)*u + (-2.763102e+01)),9.950249e-13),1.005000e-12);
      G0 = min(max((1.955225e-04)*u*u + (4.609891e-03)*u + (2.746525e-02),4.655922e-04),2.691854e-03);
      G1 = min(max((4.385883e-05)*u*u + (2.756906e-04)*u + (-2.594801e-03),-1.871394e-03),-4.361594e-04);
      w1 = min(max(exp((3.845183e-02)*u*u + (7.336197e-01)*u + (1.840430e+01)),2.989256e+06),3.182423e+06);
      G2 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      w2 = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      G3 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      w3 = min(max(exp((1.392200e-16)*u*u + (4.129372e-15)*u + (2.072327e+01)),9.950249e+08),1.005000e+09);
      pcb0 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      pcb1 = min(max((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00),0.000000e+00),0.000000e+00);
      pcw0 = min(max(exp((4.717895e-16)*u*u + (1.054077e-14)*u + (1.219951e+01)),1.977032e+05),1.996852e+05);
      pcq = min(max(exp((0.000000e+00)*u*u + (0.000000e+00)*u + (0.000000e+00)),9.950249e-01),1.005000e+00);
      gnw = min(max(exp((-5.816043e-02)*u*u + (-1.163257e+00)*u + (-1.419620e+01)),1.927712e-04),2.218001e-04);
      gn1 = min(max(exp((-1.880555e-01)*u*u + (-2.987812e+00)*u + (-1.143658e+01)),3.232568e-01),1.511190e+00);
      gn2 = min(max(exp((-1.836624e-01)*u*u + (-2.904046e+00)*u + (-1.244251e+01)),7.987602e-02),3.732192e-01);
      gn3 = min(max(exp((-2.028998e-01)*u*u + (-3.270832e+00)*u + (-1.545096e+01)),2.194388e-02),1.027696e-01);
      gn4 = min(max(exp((-1.691175e-01)*u*u + (-2.625152e+00)*u + (-1.304558e+01)),1.173510e-02),5.495468e-02);
      gn5 = min(max(exp((1.916101e+00)*u*u + (3.493460e+01)*u + (1.468397e+02)),4.199600e-06),1.084558e-03);
      gn6 = min(max(exp((-1.410392e-01)*u*u + (-3.028056e+00)*u + (-3.366225e+01)),1.180603e-08),2.759892e-08);
      vreg = min(max((2.001010e-04)*u*u + (2.410611e-03)*u + (9.065878e-01),9.003414e-01),9.039487e-01);
      Cps = 1e-12;
      // complex PSRR section: a1=1/(Q.w0), a2=1/w0^2 ; series R-L-C (Cpc fixed)
      Cpc = 1e-12;
      pca1 = 1.0/(pcq*pcw0); pca2 = 1.0/(pcw0*pcw0);
      Rpc = pca1/Cpc; Lpc = pca2/Cpc; gqb1 = pcb1/pca1;
      // R3-L1: vdd line-reg DC shift (characterized dc_linereg poly) / voutdc override
      vddc = min(max(vdd, 9.000000e-01), 1.300000e+00);
      lrsh = (-9.641010e+00)*vddc*vddc*vddc*vddc + (4.378899e+01)*vddc*vddc*vddc + (-7.433767e+01)*vddc*vddc + (5.590457e+01)*vddc + (-1.481593e+01) - (8.991185e-01);
      vregeff = (voutdc > 0) ? voutdc + R_a*ic : vreg + lrsh;
    end

    // ---- references / DC operating point ----
    V(vrf, gnd) <+ vdd;              // supply DC reference (settable; no DC coupling)
    V(vrg, gnd) <+ vregeff;          // regulated output reference (incl. R3-L1 shift)

    // ---- Zout branch C: series Cout + ESR (vout -> vrg) ----
    I(vout, nC) <+ Cout*ddt(V(vout, nC));
    V(nC, vrg)  <+ ESR*I(nC, vrg);

    // ---- Zout branch B: optional 2nd R-L (R_b->inf disables it) ----
    I(vout, nbb) <+ idt(V(vout, nbb))/L_b;
    V(nbb, vrg)  <+ R_b*I(nbb, vrg);

    // ---- Zout branch A: (L_a || R_pl) + (R_a | nonlinear dropout) ----
    // L_a||R_pl as summed current contributions (idt form admits the parallel R)
    I(vout, nA) <+ idt(V(vout, nA))/L_a + V(vout, nA)/R_pl;
    if (slew_en == 0)
      V(nA, vrg) <+ R_a*I(nA, vrg);
    else begin
      // nonlinear DC-curve branch (current-limit + dropout): INLINE closed-form PWL of
      // the characterized (Vdrop, Iload) table -- i = i1 + g1*(v-v1) + sum dg_k*max(v-v_k,0)
      // == 1-D linear table interpolation, linear end extrapolation. Self-contained
      // (no external table file -> no run-dir path issues; OpenVAF-compilable, R8 closed).
      vdrp = V(vrg, nA) - (vregeff - VREG121);
      I(vrg, nA) <+ (1.000000e-06) + (3.394369e-03)*(vdrp-(-5.378310e-03)) + (7.626646e-03)*max(vdrp-(-1.843043e-03),0) + (5.796378e-03)*max(vdrp-(-7.542137e-04),0) + (5.012260e-03)*max(vdrp-(-4.066672e-05),0)
                       + (4.397047e-03)*max(vdrp-(5.090443e-04),0) + (3.883882e-03)*max(vdrp-(9.665933e-04),0) + (3.442807e-03)*max(vdrp-(1.365124e-03),0) + (3.056422e-03)*max(vdrp-(1.722763e-03),0)
                       + (2.712922e-03)*max(vdrp-(2.050544e-03),0) + (2.404498e-03)*max(vdrp-(2.355711e-03),0) + (2.125848e-03)*max(vdrp-(2.643293e-03),0) + (1.873402e-03)*max(vdrp-(2.916934e-03),0)
                       + (1.644435e-03)*max(vdrp-(3.179364e-03),0) + (1.436358e-03)*max(vdrp-(3.432684e-03),0) + (1.247997e-03)*max(vdrp-(3.678549e-03),0) + (1.077317e-03)*max(vdrp-(3.918284e-03),0)
                       + (9.240856e-04)*max(vdrp-(4.152968e-03),0) + (7.853476e-04)*max(vdrp-(4.383486e-03),0) + (6.620508e-04)*max(vdrp-(4.610578e-03),0) + (5.504703e-04)*max(vdrp-(4.834860e-03),0)
                       + (4.515205e-04)*max(vdrp-(5.056858e-03),0) + (3.636230e-04)*max(vdrp-(5.277017e-03),0) + (2.844714e-04)*max(vdrp-(5.495717e-03),0) + (2.145304e-04)*max(vdrp-(5.713289e-03),0)
                       + (1.529394e-04)*max(vdrp-(5.930018e-03),0) + (9.701584e-05)*max(vdrp-(6.146150e-03),0) + (4.876429e-05)*max(vdrp-(6.361905e-03),0) + (4.648678e-06)*max(vdrp-(6.577471e-03),0)
                       + (-3.381432e-05)*max(vdrp-(6.793019e-03),0) + (-6.827758e-05)*max(vdrp-(7.008698e-03),0) + (-9.915410e-05)*max(vdrp-(7.224642e-03),0) + (-1.266369e-04)*max(vdrp-(7.440972e-03),0)
                       + (-1.514570e-04)*max(vdrp-(7.657797e-03),0) + (-1.730909e-04)*max(vdrp-(7.875217e-03),0) + (-1.938098e-04)*max(vdrp-(8.093321e-03),0) + (-2.118436e-04)*max(vdrp-(8.312196e-03),0)
                       + (-2.284586e-04)*max(vdrp-(8.531920e-03),0) + (-2.441486e-04)*max(vdrp-(8.752567e-03),0) + (-2.584238e-04)*max(vdrp-(8.974209e-03),0) + (-2.722601e-04)*max(vdrp-(9.196914e-03),0)
                       + (-2.851670e-04)*max(vdrp-(9.420750e-03),0) + (3.578365e-04)*max(vdrp-(9.645783e-03),0) + (-9.450441e-04)*max(vdrp-(9.794805e-03),0) + (-5.432412e-04)*max(vdrp-(1.017404e-02),0)
                       + (-5.768318e-04)*max(vdrp-(1.055721e-02),0) + (-6.121363e-04)*max(vdrp-(1.094467e-02),0) + (-6.503318e-04)*max(vdrp-(1.133678e-02),0) + (-6.923572e-04)*max(vdrp-(1.173396e-02),0)
                       + (-7.397272e-04)*max(vdrp-(1.213667e-02),0) + (-7.939984e-04)*max(vdrp-(1.254547e-02),0) + (-8.569619e-04)*max(vdrp-(1.296101e-02),0) + (-9.304019e-04)*max(vdrp-(1.338409e-02),0)
                       + (-1.017051e-03)*max(vdrp-(1.381566e-02),0) + (-1.119727e-03)*max(vdrp-(1.425692e-02),0) + (-1.242184e-03)*max(vdrp-(1.470935e-02),0) + (-1.387894e-03)*max(vdrp-(1.517486e-02),0)
                       + (-1.561055e-03)*max(vdrp-(1.565591e-02),0) + (-1.765077e-03)*max(vdrp-(1.615573e-02),0) + (-2.000962e-03)*max(vdrp-(1.667862e-02),0) + (-2.264815e-03)*max(vdrp-(1.723037e-02),0)
                       + (-2.543190e-03)*max(vdrp-(1.781889e-02),0) + (-2.808520e-03)*max(vdrp-(1.845501e-02),0) + (-3.015054e-03)*max(vdrp-(1.915354e-02),0) + (-3.103950e-03)*max(vdrp-(1.993427e-02),0)
                       + (-3.021978e-03)*max(vdrp-(2.082266e-02),0) + (-2.751530e-03)*max(vdrp-(2.184878e-02),0) + (-2.332775e-03)*max(vdrp-(2.304357e-02),0) + (-1.852296e-03)*max(vdrp-(2.443183e-02),0)
                       + (-1.400378e-03)*max(vdrp-(2.602491e-02),0) + (-1.031311e-03)*max(vdrp-(2.781801e-02),0) + (-7.560195e-04)*max(vdrp-(2.979379e-02),0) + (-5.600310e-04)*max(vdrp-(3.192905e-02),0)
                       + (-4.225215e-04)*max(vdrp-(3.420010e-02),0) + (-3.256190e-04)*max(vdrp-(3.658559e-02),0) + (-2.564047e-04)*max(vdrp-(3.906748e-02),0) + (-2.060781e-04)*max(vdrp-(4.163094e-02),0)
                       + (-1.687923e-04)*max(vdrp-(4.426394e-02),0) + (-1.406640e-04)*max(vdrp-(4.695678e-02),0) + (-1.190643e-04)*max(vdrp-(4.970160e-02),0) + (-1.022191e-04)*max(vdrp-(5.249202e-02),0)
                       + (-8.888188e-05)*max(vdrp-(5.532282e-02),0) + (-7.817109e-05)*max(vdrp-(5.818968e-02),0) + (-6.947687e-05)*max(vdrp-(6.108903e-02),0) + (-6.232530e-05)*max(vdrp-(6.401787e-02),0)
