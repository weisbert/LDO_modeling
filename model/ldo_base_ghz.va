                       + (-3.177117e-05)*max(vdrp-(9.138884e-02),0) + (-3.019522e-05)*max(vdrp-(9.451956e-02),0) + (-2.879964e-05)*max(vdrp-(9.766514e-02),0) + (-2.755322e-05)*max(vdrp-(1.008250e-01),0)
                       + (-2.643632e-05)*max(vdrp-(1.039987e-01),0) + (-2.543626e-05)*max(vdrp-(1.071858e-01),0) + (-2.453338e-05)*max(vdrp-(1.103859e-01),0) + (-2.371853e-05)*max(vdrp-(1.135985e-01),0)
                       + (-2.297543e-05)*max(vdrp-(1.168235e-01),0) + (-2.230747e-05)*max(vdrp-(1.200604e-01),0) + (-2.169351e-05)*max(vdrp-(1.233091e-01),0) + (-2.113380e-05)*max(vdrp-(1.265693e-01),0)
                       + (-2.062676e-05)*max(vdrp-(1.298407e-01),0) + (-2.015800e-05)*max(vdrp-(1.331232e-01),0) + (-1.973012e-05)*max(vdrp-(1.364166e-01),0) + (-1.934023e-05)*max(vdrp-(1.397207e-01),0)
                       + (-1.897827e-05)*max(vdrp-(1.430355e-01),0) + (-1.864715e-05)*max(vdrp-(1.463606e-01),0) + (-1.834965e-05)*max(vdrp-(1.496962e-01),0) + (-1.806720e-05)*max(vdrp-(1.530419e-01),0)
                       + (-1.781710e-05)*max(vdrp-(1.563978e-01),0) + (-1.758454e-05)*max(vdrp-(1.597638e-01),0) + (-1.737435e-05)*max(vdrp-(1.631398e-01),0) + (-1.718082e-05)*max(vdrp-(1.665257e-01),0)
