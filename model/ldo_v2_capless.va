                       + (-3.609312e-06)*max(vdrp-(1.424507e+00),0) + (-3.356714e-06)*max(vdrp-(1.452002e+00),0) + (-3.119884e-06)*max(vdrp-(1.479624e+00),0) + (-2.897842e-06)*max(vdrp-(1.507366e+00),0)
                       + (-2.689471e-06)*max(vdrp-(1.535220e+00),0) + (-2.493900e-06)*max(vdrp-(1.563179e+00),0) + (-2.310282e-06)*max(vdrp-(1.591235e+00),0) + (-2.137815e-06)*max(vdrp-(1.619383e+00),0)
                       + (-1.975660e-06)*max(vdrp-(1.647615e+00),0) + (-1.823256e-06)*max(vdrp-(1.675927e+00),0) + (-1.679870e-06)*max(vdrp-(1.704312e+00),0) + (-1.544959e-06)*max(vdrp-(1.732764e+00),0)
                       + (-1.417922e-06)*max(vdrp-(1.761280e+00),0) + (-1.298241e-06)*max(vdrp-(1.789853e+00),0) + (-1.185430e-06)*max(vdrp-(1.818479e+00),0) + (-1.079173e-06)*max(vdrp-(1.847154e+00),0)
                       + (-9.787200e-07)*max(vdrp-(1.875873e+00),0) + (-8.842850e-07)*max(vdrp-(1.904633e+00),0) + (-7.947709e-07)*max(vdrp-(1.933429e+00),0) + (-7.103542e-07)*max(vdrp-(1.962258e+00),0)
