                       + (-3.928914e-05)*max(vdrp-(8.536095e-02),0) + (-3.714540e-05)*max(vdrp-(8.825346e-02),0) + (-3.526712e-05)*max(vdrp-(9.116159e-02),0) + (-3.362118e-05)*max(vdrp-(9.408472e-02),0)
                       + (-3.217218e-05)*max(vdrp-(9.702228e-02),0) + (-3.089829e-05)*max(vdrp-(9.997378e-02),0) + (-2.977230e-05)*max(vdrp-(1.029388e-01),0) + (-2.878191e-05)*max(vdrp-(1.059170e-01),0)
                       + (-2.790668e-05)*max(vdrp-(1.089080e-01),0) + (-2.713601e-05)*max(vdrp-(1.119115e-01),0) + (-2.646420e-05)*max(vdrp-(1.149273e-01),0) + (-2.586859e-05)*max(vdrp-(1.179552e-01),0)
                       + (-2.535105e-05)*max(vdrp-(1.209950e-01),0) + (-2.490707e-05)*max(vdrp-(1.240466e-01),0) + (-2.451751e-05)*max(vdrp-(1.271098e-01),0) + (-2.419549e-05)*max(vdrp-(1.301845e-01),0)
                       + (-2.391819e-05)*max(vdrp-(1.332707e-01),0) + (-2.369676e-05)*max(vdrp-(1.363684e-01),0) + (-2.351524e-05)*max(vdrp-(1.394775e-01),0) + (-2.338268e-05)*max(vdrp-(1.425980e-01),0)
                       + (-2.328354e-05)*max(vdrp-(1.457299e-01),0) + (-2.322890e-05)*max(vdrp-(1.488732e-01),0) + (-2.320353e-05)*max(vdrp-(1.520281e-01),0) + (-2.321646e-05)*max(vdrp-(1.551946e-01),0)
