                       + (5.351207e-08)*max(vdrp-(2.338687e+00),0) + (9.324975e-08)*max(vdrp-(2.367684e+00),0) + (1.311156e-07)*max(vdrp-(2.396678e+00),0) + (1.671197e-07)*max(vdrp-(2.425666e+00),0)
