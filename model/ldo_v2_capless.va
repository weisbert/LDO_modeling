                       + (-3.526206e-07)*max(vdrp-(2.106785e+00),0) + (-2.912726e-07)*max(vdrp-(2.135746e+00),0) + (-2.346031e-07)*max(vdrp-(2.164718e+00),0) + (-1.794768e-07)*max(vdrp-(2.193701e+00),0)
