                       + (6.817331e-07)*max(vdrp-(3.145234e+00),0) + (6.926929e-07)*max(vdrp-(3.173716e+00),0) + (7.032187e-07)*max(vdrp-(3.202171e+00),0) + (7.128116e-07)*max(vdrp-(3.230597e+00),0)
