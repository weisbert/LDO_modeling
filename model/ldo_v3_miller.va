                       + (-3.707971e-05)*max(vdrp-(4.809415e-02),0) + (-3.712439e-05)*max(vdrp-(5.086163e-02),0) + (-3.719770e-05)*max(vdrp-(5.364339e-02),0) + (-3.729323e-05)*max(vdrp-(5.643961e-02),0)
                       + (-3.741485e-05)*max(vdrp-(5.925050e-02),0) + (-3.754141e-05)*max(vdrp-(6.207624e-02),0) + (-3.768225e-05)*max(vdrp-(6.491705e-02),0) + (-3.782919e-05)*max(vdrp-(6.777315e-02),0)
                       + (-3.798648e-05)*max(vdrp-(7.064476e-02),0) + (-3.814384e-05)*max(vdrp-(7.353212e-02),0) + (-3.831033e-05)*max(vdrp-(7.643547e-02),0) + (-3.847823e-05)*max(vdrp-(7.935505e-02),0)
                       + (-3.865399e-05)*max(vdrp-(8.229113e-02),0) + (-3.883234e-05)*max(vdrp-(8.524396e-02),0) + (-3.901052e-05)*max(vdrp-(8.821382e-02),0) + (-3.919920e-05)*max(vdrp-(9.120098e-02),0)
                       + (-3.938652e-05)*max(vdrp-(9.420574e-02),0) + (-3.958073e-05)*max(vdrp-(9.722838e-02),0) + (-3.977892e-05)*max(vdrp-(1.002692e-01),0) + (-3.997617e-05)*max(vdrp-(1.033285e-01),0)
                       + (-4.018037e-05)*max(vdrp-(1.064067e-01),0) + (-4.039064e-05)*max(vdrp-(1.095040e-01),0) + (-4.060005e-05)*max(vdrp-(1.126208e-01),0) + (-4.081609e-05)*max(vdrp-(1.157575e-01),0)
                       + (-4.103783e-05)*max(vdrp-(1.189143e-01),0) + (-4.126044e-05)*max(vdrp-(1.220918e-01),0) + (-4.148709e-05)*max(vdrp-(1.252902e-01),0) + (-4.172260e-05)*max(vdrp-(1.285100e-01),0)
