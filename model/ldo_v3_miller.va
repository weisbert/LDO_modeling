                       + (6.696185e-07)*max(vdrp-(3.111191e+00),0) + (6.812040e-07)*max(vdrp-(3.139774e+00),0) + (6.916247e-07)*max(vdrp-(3.168329e+00),0) + (7.030883e-07)*max(vdrp-(3.196856e+00),0)
