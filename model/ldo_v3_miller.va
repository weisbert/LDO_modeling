                       + (-3.040753e-06)*max(vdrp-(1.498702e+00),0) + (-2.822399e-06)*max(vdrp-(1.526552e+00),0) + (-2.617520e-06)*max(vdrp-(1.554512e+00),0) + (-2.425264e-06)*max(vdrp-(1.582575e+00),0)
                       + (-2.244804e-06)*max(vdrp-(1.610733e+00),0) + (-2.075257e-06)*max(vdrp-(1.638981e+00),0) + (-1.915973e-06)*max(vdrp-(1.667312e+00),0) + (-1.766209e-06)*max(vdrp-(1.695720e+00),0)
                       + (-1.625345e-06)*max(vdrp-(1.724200e+00),0) + (-1.492801e-06)*max(vdrp-(1.752745e+00),0) + (-1.368038e-06)*max(vdrp-(1.781352e+00),0) + (-1.250522e-06)*max(vdrp-(1.810014e+00),0)
                       + (-1.139754e-06)*max(vdrp-(1.838728e+00),0) + (-1.035329e-06)*max(vdrp-(1.867489e+00),0) + (-9.368213e-07)*max(vdrp-(1.896293e+00),0) + (-8.440142e-07)*max(vdrp-(1.925136e+00),0)
                       + (-7.560632e-07)*max(vdrp-(1.954014e+00),0) + (-6.734581e-07)*max(vdrp-(1.982923e+00),0) + (-5.949070e-07)*max(vdrp-(2.011861e+00),0) + (-5.208052e-07)*max(vdrp-(2.040824e+00),0)
                       + (-4.510782e-07)*max(vdrp-(2.069808e+00),0) + (-3.844729e-07)*max(vdrp-(2.098812e+00),0) + (-3.218858e-07)*max(vdrp-(2.127832e+00),0) + (-2.623186e-07)*max(vdrp-(2.156865e+00),0)
                       + (-2.059673e-07)*max(vdrp-(2.185909e+00),0) + (-1.527960e-07)*max(vdrp-(2.214962e+00),0) + (-1.018263e-07)*max(vdrp-(2.244022e+00),0) + (-5.421614e-08)*max(vdrp-(2.273085e+00),0)
                       + (-8.285556e-09)*max(vdrp-(2.302151e+00),0) + (3.503743e-08)*max(vdrp-(2.331218e+00),0) + (7.600561e-08)*max(vdrp-(2.360283e+00),0) + (1.151059e-07)*max(vdrp-(2.389344e+00),0)
                       + (1.525864e-07)*max(vdrp-(2.418401e+00),0) + (1.875086e-07)*max(vdrp-(2.447451e+00),0) + (2.215386e-07)*max(vdrp-(2.476494e+00),0) + (2.532598e-07)*max(vdrp-(2.505527e+00),0)
