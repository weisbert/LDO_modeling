                       + (-1.633277e-03)*max(vdrp-(1.684037e-02),0) + (-1.737589e-03)*max(vdrp-(1.709025e-02),0) + (-1.849776e-03)*max(vdrp-(1.734567e-02),0) + (-1.969390e-03)*max(vdrp-(1.760728e-02),0)
                       + (-2.096488e-03)*max(vdrp-(1.787579e-02),0) + (-2.230391e-03)*max(vdrp-(1.815209e-02),0) + (-2.368097e-03)*max(vdrp-(1.843717e-02),0) + (-2.507531e-03)*max(vdrp-(1.873221e-02),0)
                       + (-2.645060e-03)*max(vdrp-(1.903858e-02),0) + (-2.775607e-03)*max(vdrp-(1.935789e-02),0) + (-2.893188e-03)*max(vdrp-(1.969201e-02),0) + (-2.990691e-03)*max(vdrp-(2.004309e-02),0)
                       + (-3.060111e-03)*max(vdrp-(2.041363e-02),0) + (-3.094311e-03)*max(vdrp-(2.080644e-02),0) + (-3.087026e-03)*max(vdrp-(2.122466e-02),0) + (-3.032879e-03)*max(vdrp-(2.167175e-02),0)
                       + (-2.931787e-03)*max(vdrp-(2.215135e-02),0) + (-2.785744e-03)*max(vdrp-(2.266722e-02),0) + (-2.601197e-03)*max(vdrp-(2.322303e-02),0) + (-2.388220e-03)*max(vdrp-(2.382214e-02),0)
