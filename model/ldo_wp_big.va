                       + (-1.633981e-05)*max(vdrp-(1.915881e-01),0) + (-1.630734e-05)*max(vdrp-(1.933118e-01),0) + (-1.628165e-05)*max(vdrp-(1.950379e-01),0) + (-1.625598e-05)*max(vdrp-(1.967665e-01),0)
                       + (-1.624364e-05)*max(vdrp-(1.984975e-01),0) + (-1.622458e-05)*max(vdrp-(2.002309e-01),0) + (-1.621873e-05)*max(vdrp-(2.019668e-01),0) + (-1.621273e-05)*max(vdrp-(2.037051e-01),0)
                       + (-1.621317e-05)*max(vdrp-(2.054458e-01),0) + (-1.621342e-05)*max(vdrp-(2.071891e-01),0) + (-1.622001e-05)*max(vdrp-(2.089348e-01),0) + (-1.623941e-05)*max(vdrp-(2.106830e-01),0)
                       + (-1.625193e-05)*max(vdrp-(2.124336e-01),0) + (-1.627065e-05)*max(vdrp-(2.141868e-01),0) + (-1.630194e-05)*max(vdrp-(2.159424e-01),0) + (-1.632632e-05)*max(vdrp-(2.177006e-01),0)
                       + (-1.637602e-05)*max(vdrp-(2.194613e-01),0) + (-1.640584e-05)*max(vdrp-(2.212245e-01),0) + (-1.645439e-05)*max(vdrp-(2.229903e-01),0) + (-1.651506e-05)*max(vdrp-(2.247587e-01),0)
                       + (-1.656227e-05)*max(vdrp-(2.265296e-01),0) + (-1.663422e-05)*max(vdrp-(2.283032e-01),0) + (-1.670531e-05)*max(vdrp-(2.300794e-01),0) + (-1.678186e-05)*max(vdrp-(2.318582e-01),0)
                       + (-1.686378e-05)*max(vdrp-(2.336397e-01),0) + (-1.695100e-05)*max(vdrp-(2.354238e-01),0) + (-1.705594e-05)*max(vdrp-(2.372107e-01),0) + (-1.715969e-05)*max(vdrp-(2.390002e-01),0)
                       + (-1.726844e-05)*max(vdrp-(2.407926e-01),0) + (-1.738832e-05)*max(vdrp-(2.425877e-01),0) + (-1.752533e-05)*max(vdrp-(2.443856e-01),0) + (-1.765464e-05)*max(vdrp-(2.461863e-01),0)
                       + (-1.780697e-05)*max(vdrp-(2.479900e-01),0) + (-1.795757e-05)*max(vdrp-(2.497965e-01),0) + (-1.812469e-05)*max(vdrp-(2.516059e-01),0) + (-1.830201e-05)*max(vdrp-(2.534184e-01),0)
                       + (-1.848333e-05)*max(vdrp-(2.552338e-01),0) + (-1.868662e-05)*max(vdrp-(2.570523e-01),0) + (-1.888753e-05)*max(vdrp-(2.588739e-01),0) + (-1.910998e-05)*max(vdrp-(2.606986e-01),0)
                       + (-1.933574e-05)*max(vdrp-(2.625265e-01),0) + (-1.958846e-05)*max(vdrp-(2.643577e-01),0) + (-1.983218e-05)*max(vdrp-(2.661921e-01),0) + (-2.011416e-05)*max(vdrp-(2.680299e-01),0)
                       + (-2.038674e-05)*max(vdrp-(2.698711e-01),0) + (-2.069096e-05)*max(vdrp-(2.717157e-01),0) + (-2.099711e-05)*max(vdrp-(2.735639e-01),0) + (-2.132827e-05)*max(vdrp-(2.754156e-01),0)
                       + (-2.166661e-05)*max(vdrp-(2.772711e-01),0) + (-2.202342e-05)*max(vdrp-(2.791302e-01),0) + (-2.239827e-05)*max(vdrp-(2.809932e-01),0) + (-2.279073e-05)*max(vdrp-(2.828601e-01),0)
