                       + (-3.503526e-05)*max(vdrp-(3.231530e-01),0) + (-3.580473e-05)*max(vdrp-(3.251350e-01),0) + (-3.658038e-05)*max(vdrp-(3.271242e-01),0) + (-3.737621e-05)*max(vdrp-(3.291205e-01),0)
