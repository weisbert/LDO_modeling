# --- Python ---
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# --- ngspice: Windows binaries are platform-specific (install ngspice on the target OS) ---
tools/

# --- xwin MSVC/SDK import-lib cache (large; splatted from Microsoft CDN by xwin, rebuildable) ---
.xwin-cache/

# --- ngspice run scratch dirs (per-process LDO_WORK; regenerated each run) ---
work/
work_*/

# --- scratch / scratchpad outputs ---
out.dat
*.raw
defect.txt.bak

# --- third-party reference-paper extracts (not our work; kept out of the repo) ---
_extract/
_research_tmp/

# --- generated plots & per-variant logs (regenerated by score.py / run_matrix.py) ---
results/score/
results/*.png
results/generalization/*.png
results/generalization/*.log
# regression-gate snapshots (temporary; matrix.json/.md are the tracked outputs)
results/generalization/matrix_baseline.json
results/generalization/matrix_postrefactor.json
results/generalization/matrix_postfix.json
results/generalization/matrix_committed.json

# --- offline deploy bundles (large wheels tarballs; rebuilt by deploy/package.py) ---
dist/

# --- local Claude Code session state (not project source) ---
.claude/

# --- Target B (Cadence/Spectre) scratch + regenerable validation artifacts ---
cadence/work/
cadence/work_*/
# generated OA library (regenerate via: python cadence/skill_lib.py)
cadence/cds/
model/*_spectre.lib
model/*_spectre.va
model/*_spectre_dropout.tbl
model/ldo_va_*
results/ref/*_spectre.npz
results/ref/va_*.npz

# --- Mechanism A (insitu) regenerable outputs ---
# produced on demand by `python -m insitu run` / fit_multiport --emit; not checked in
# (the trusted gold results/ref/pmu_standin.npz IS tracked).
results/ref/*_spectre_cli*.npz
results/ref/*_ade*.npz
results/ref/pmu_standin_pll.npz
results/ref/pmu_standin_vco.npz
model/pmu_standin_*.va
model/pmu_standin_*.lib
model/pmu_standin_*_dropout.tbl
cadence/insitu/__pycache__/

# --- OS cruft ---
.DS_Store
Thumbs.db

# red-zone real-chip GT (characterization data) — keep LOCAL, never push
results/redzone/
