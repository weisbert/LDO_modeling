# --- Python ---
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# --- ngspice: Windows binaries are platform-specific (install ngspice on the target OS) ---
tools/

# --- xwin MSVC/SDK import-lib cache (large; splatted from Microsoft CDN by xwin, rebuildable) ---
.xwin-cache/

# --- ngspice run scratch dirs (per-process LDO_WORK; regenerated each run) ---
work/
work_*/

# --- scratch / scratchpad outputs ---
out.dat
*.raw
defect.txt.bak

# --- third-party reference-paper extracts (not our work; kept out of the repo) ---
_extract/
_research_tmp/

# --- generated plots & per-variant logs (regenerated by score.py / run_matrix.py) ---
results/score/
results/*.png
results/generalization/*.png
results/generalization/*.log
# regression-gate snapshots (temporary; matrix.json/.md are the tracked outputs)
results/generalization/matrix_baseline.json
results/generalization/matrix_postrefactor.json
results/generalization/matrix_postfix.json
results/generalization/matrix_committed.json

# --- offline deploy bundles (large wheels tarballs; rebuilt by deploy/package.py) ---
dist/

# --- local Claude Code session state (not project source) ---
.claude/

# --- OS cruft ---
.DS_Store
Thumbs.db
