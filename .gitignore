# --- Python ---
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# --- ngspice: Windows binaries are platform-specific (install ngspice on the target OS) ---
tools/

# --- ngspice run scratch dirs (per-process LDO_WORK; regenerated each run) ---
work/
work_*/

# --- scratch / scratchpad outputs ---
out.dat
*.raw
defect.txt.bak

# --- third-party reference-paper extracts (not our work; kept out of the repo) ---
_extract/
_research_tmp/

# --- generated plots & per-variant logs (regenerated by score.py / run_matrix.py) ---
results/score/
results/*.png
results/generalization/*.png
results/generalization/*.log

# --- Target B (Cadence/Spectre) scratch + regenerable validation artifacts ---
cadence/work/
cadence/work_*/
# generated OA library (regenerate via: python cadence/skill_lib.py)
cadence/cds/
model/*_spectre.lib
model/*_spectre.va
model/*_spectre_dropout.tbl
model/ldo_va_*
results/ref/*_spectre.npz
results/ref/va_*.npz

# --- OS cruft ---
.DS_Store
Thumbs.db
